APP_ENV=test
APP_DEBUG=1
DATABASE_URL="postgresql://user:password@db:5432/eshop?serverVersion=15&charset=utf8"
MAX_ARTICLES_COUNT_PER_PAGE=10
NAME_MAX_LENGTH=32
CONTENT_MAX_LENGTH=1024
###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###
