                            </svg>
                        </a>
                    {% endif %}
                    <form id="locale-switcher" method="get">
                        <select name="_locale" onchange="this.form.submit()">
                            {% set currentLocale = locale ?? 'en' %}

                            {# 默认英语 #}
                            <option value="en" {% if currentLocale == 'en' %}selected{% endif %}>EN</option>

                            {# 其他语言，排除 en 避免重复 #}
                            {% for lang in languages %}
                            {% if lang != 'en' %}
                                <option value="{{ lang }}" {% if lang == currentLocale %}selected{% endif %}>{{ lang|upper }}</option>
                            {% endif %}
                            {% endfor %}
                        </select>
                    </form>
                </div>
            </header>

            <!-- 添加遮罩层 -->
            <div class="overlay"></div>

