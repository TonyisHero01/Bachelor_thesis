                </div>
                <div class="mobile-categories-content">
                    <ul class="categories-list">
                        {% for category in categories %}
                            <li>
                                <a href="{{ path('app_eshop_category', {'id': category.id}) }}">{{ category.name }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <!-- Main Body (Sidebar and Content) -->
            <div class="main-body">
                {% if show_sidebar %}
                    <aside class="eshop-sidebar">
                        <h3>Filters</h3>
                        <!-- Price Range Filter -->
                        <!-- 价格过滤 -->
                        <!-- 价格过滤 -->
                        {% if not shopInfo.getHidePrices() %}
                            <!-- 价格过滤 -->
                            <div class="filter-section">
                                <h4>Price</h4>

                                <!-- noUiSlider 滑块 -->
                                <div id="price-slider"></div>

                                <!-- 选中价格显示 -->
                                <div class="price-values">
                                    <span id="price-selected-min">0</span> - <span id="price-selected-max">1000</span>
                                </div>
                            </div>

                            <!-- noUiSlider 依赖 -->
                            <script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.7.1/nouislider.min.js"></script>
                        {% endif %}
                        <!-- Color Filter -->
                        <!-- 颜色过滤 -->
                        <div class="filter-section">
                            <h4>Color</h4>
                            <div class="color-options">
                                {% for color in colors %}
                                    <label class="custom-checkbox circle">
                                        <input type="checkbox" name="color" value="{{ color.id }}">
                                        <span class="checkmark" id="checkmark-{{ color.id }}" style="background-color: {{ color.hex }};"></span>
                                        {{ color.getTranslatedName(locale) }}
                                    </label>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- ✅ 读取数据库中的尺寸数据 -->
                        <div class="filter-section">
                            <h4>Size</h4>
                            <div class="size-options">
                                {% for size in sizes %}
                                    <label class="custom-checkbox large">
                                        <input type="checkbox" name="size" value="{{ size.id }}">
                                        <span class="checkmark"></span> {{ size.name }}
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                        <button id="reset-filters" class="filter-button reset">Reset Filters</button>

                        <!-- Apply Filter Button -->
                        <button id="apply-filters" class="filter-button apply">Apply Filters</button>
                    </aside>
                    <style>
                    /* 主体内容区域，包含 Sidebar 和 Content */
                    .main-body {
                        display: grid;
                        grid-template-columns: 1fr 3fr;
                        gap: 0; /* 消除 Sidebar 和 Content 之间的空隙 */
                        flex: 1;
                    }
                    </style>
                {% endif %}
                <main class="product-content">
                    {% block body %}{% endblock %}
                </main>
            </div>

            <!-- Footer -->
            <footer class="footer">
                <div class="footer-content">
                    <div class="footer-left">
                        <h3>{{ shopInfo.getEshopName() }}</h3>
                        <p>{{ shopInfo.address }}</p>
                        <p>📞 {{ shopInfo.telephone }}</p>
                        <p>✉️ {{ shopInfo.email }}</p>
                    </div>

                    <div class="footer-right">
                        <h3>Information</h3>
                        <div class="footer-links-grid">
                            <a href="{{ path('page_about_us') }}" class="static-link">About Us</a>
                            <a href="{{ path('page_how_to_order') }}" class="static-link">How To Order</a>
                            <a href="{{ path('page_business_conditions') }}" class="static-link">Business Conditions</a>
                            <a href="{{ path('page_privacy_policy') }}" class="static-link">Privacy Policy</a>
                            <a href="{{ path('page_shipping_info') }}" class="static-link">Shipping Info</a>
                            <a href="{{ path('page_payment') }}" class="static-link">Payment</a>
                            <a href="{{ path('page_refund') }}" class="static-link">Refund</a>
                        </div>
                    </div>
                </div>

                <div class="footer-bottom">
                    <p>© {{ "now"|date("Y") }} {{ shopInfo.getEshopName() }}. All rights reserved.</p>
                </div>
            </footer>

            <!-- 移动端搜索弹窗 -->
            <div class="mobile-search-overlay" id="mobile-search-overlay">
                <div class="mobile-search-container">
                    <div class="mobile-search-header">
                        <button class="close-search">
                            <svg viewBox="0 0 24 24">
                                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="mobile-search-content">
                        <div class="mobile-search-form">
                            <input type="text" class="mobile-search__input" placeholder="搜索产品...">
                            <button type="button" class="mobile-search__button">
                                <svg class="icon-search" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                                    <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
