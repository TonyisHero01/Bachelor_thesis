{% extends 'eshop_base.html.twig' %}

{% block title %}Select Delivery Option - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/order-delivery.css') }}">

    <div class="delivery-options">
        <h2>Choose Delivery Method</h2>

        <form id="deliveryForm">
            <input type="hidden" name="orderId" value="{{ order.getId() }}">

            <label>
                <input type="radio" name="deliveryMethod" value="pickup" checked>
                Pick Up at Store
            </label>

            <label>
                <input type="radio" name="deliveryMethod" value="delivery">
                Home Delivery
            </label>

            <div id="addressField" style="display: none;">
                <label>Delivery Address:</label>
                <input type="text" name="deliveryAddress" id="deliveryAddress">
            </div>

            <button type="submit">Confirm</button>
        </form>
    </div>

    <script>
        document.querySelectorAll('input[name="deliveryMethod"]').forEach((radio) => {
            radio.addEventListener("change", function() {
                document.getElementById("addressField").style.display = 
                    this.value === "delivery" ? "block" : "none";
            });
        });

        document.getElementById("deliveryForm").addEventListener("submit", function(event) {
            event.preventDefault();

            const deliveryMethod = document.querySelector('input[name="deliveryMethod"]:checked').value;
            const address = document.getElementById("deliveryAddress").value.trim();
            const orderId = "{{ order.getId() }}";  // 获取订单 ID

            if (deliveryMethod === "delivery" && !address) {
                alert("Please enter a delivery address.");
                return;
            }

            fetch(`/order/submit_delivery/${orderId}`, {  // 这里直接拼接 URL
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ deliveryMethod, address: address || "" }) // 如果是 pickup，地址设为空字符串
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = `/order/success/${orderId}`;  // 跳转到成功页面
                } else {
                    alert("Error: " + data.message);
                }
            })
            .catch(error => console.error("Error:", error));
        });
    </script>
{% endblock %}