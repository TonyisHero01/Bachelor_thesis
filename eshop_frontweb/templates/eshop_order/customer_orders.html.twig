{# templates/eshop_order/customer_orders.html.twig #}
{% extends 'eshop_base.html.twig' %}

{% block title %}My Orders - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('assets/eshop_styles/order-list.css') }}">

<div class="customer-orders">
  <h2>My Orders</h2>

  {% if orders is empty %}
    <p>You have no orders.</p>
  {% else %}
    <table class="order-table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Order Date</th>
          {% if not shopInfo.hidePrices %}
            <th>Total Price</th>
          {% endif %}
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
      {% for order in orders %}
        {% set hasShipment = order.getShipment() is not null %}
        <tr>
          <td data-label="Order ID">{{ order.getId() }}</td>
          <td data-label="Order Date">{{ order.getOrderCreatedAt()|date('Y-m-d H:i') }}</td>

          {% if not shopInfo.hidePrices %}
            <td data-label="Total Price">
              {{ money(order.getTotalPrice()) }}
            </td>
          {% endif %}

          <td data-label="Status">
            {% if order.getIsCompleted() %}
              <span class="status completed">COMPLETED</span>
            {% else %}
              <span class="status pending">PENDING</span>
            {% endif %}
          </td>

          <td data-label="Action">
            <a href="{{ path('order_confirmation2', {'id': order.getId(), '_locale': locale}) }}" class="btn">View</a>

            {% if hasShipment %}
              <a href="{{ path('frontweb_track_my_order', {'id': order.getId(), '_locale': locale}) }}" class="btn" style="margin-left:.5rem;">
                Track
              </a>
            {% else %}
              <span class="btn disabled" style="margin-left:.5rem; opacity:.6; cursor:not-allowed;">Not shipped yet</span>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  {% endif %}

  <a href="{{ path('app_eshop_home', {'_locale': locale}) }}" class="btn return-home">
    <i class="fas fa-home"></i> Return to Home
  </a>
</div>
{% endblock %}