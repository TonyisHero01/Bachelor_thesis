{% extends 'eshop_base.html.twig' %}

{% block title %}Search Results - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('assets/eshop_styles/search-results.css') }}">

    <h1 class="search-title">Search Results</h1>

    {% if products is empty %}
        <p class="no-results">No products found.</p>
    {% else %}
        <div class="product-grid">
            {% for product in products %}
                <div class="product-item">
                    <a href="{{ path('show_eshop_product', {'id': product.id, '_locale': locale}) }}">
                        <div class="product-image-container">
                            <img
                                src="{{ product.getImageUrls() is not empty and product.getImageUrls()[0] is defined
                                    ? BMS_URL ~ '/images/' ~ product.getImageUrls()[0]
                                    : asset('images/fallback-product.png') }}"
                                alt="{{ product.name }}"
                                class="product-image"
                                onerror="this.onerror=null;this.src='{{ asset('images/fallback-product.png') }}';"
                            >
                        </div>
                        <p class="product-name">{{ product.name }}</p>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}