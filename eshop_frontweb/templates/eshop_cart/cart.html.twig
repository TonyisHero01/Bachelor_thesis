{% extends 'eshop_base.html.twig' %}

{% block title %}Your Cart - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/product-page.css') }}">
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/cart.css') }}">
    <h2>Your Shopping Cart</h2>

    {% if cartItems is empty %}
        <p>Your cart is empty.</p>
    {% else %}
        <table class="cart-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for cartItem in cartItems %}
                    <tr>
                        <td class="cart-item">
                        {% if cartItem.getProduct().getImageUrls() is not empty %}
                            <img class="product-img" src="{{ BMS_URL }}/images/{{ cartItem.getProduct().getImageUrls()|first }}" alt="{{ cartItem.getProduct().getName() }}" class="cart-product-image">
                        {% endif %}
                        {{ cartItem.getProduct().getName() }}
                        </td>
                        <td>{{ cartItem.getProduct().getPrice() }} {{ cartItem.getProduct().getCurrency().getName() }}</td>
                        <td>
                            <div class="quantity-selector">
                                <button class="quantity-btn" onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() - 1 }})">-</button>
                                <span class="quantity-value" id="cart-quantity-{{ cartItem.getId() }}">{{ cartItem.getQuantity() }}</span>
                                <button class="quantity-btn" onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() + 1 }})">+</button>
                            </div>
                        </td>
                        <td>{{ (cartItem.getQuantity() * cartItem.getProduct().getPrice()) | number_format(2) }}</td>
                        <td>
                            <button class="remove-btn" onclick="removeFromCart({{ cartItem.getId() }})">Remove</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="total-row">
            <p><strong>Total:</strong> {{ cartItems|reduce((carry, item) => carry + item.getQuantity() * item.getProduct().getPrice(), 0) | number_format(2) }}</p>
        </div>
        <div class="checkout-container">
            <button class="checkout-btn" onclick="checkout()">Proceed to Checkout</button>
        </div>
    {% endif %}

    <script>
        function updateCart(cartItemId, newQuantity) {
            if (newQuantity < 1) return;

            fetch('/cart/update/' + cartItemId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ quantity: newQuantity })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('cart-quantity-' + cartItemId).textContent = newQuantity;
                    updateCartCount(data.cartCount);
                    location.reload(); // 刷新购物车页面
                } else {
                    alert('Error updating cart: ' + data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function removeFromCart(cartItemId) {
            fetch('/cart/remove/' + cartItemId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateCartCount(data.cartCount);
                    location.reload(); // 刷新购物车页面
                } else {
                    alert('Error removing item: ' + data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function checkout() {
            fetch('/cart/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({})
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert("Order created successfully! Order ID: " + data.order_id);
                    location.href = "/order-confirmation/" + data.order_id;
                } else {
                    alert("Error: " + data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }
    </script>
{% endblock %}