{# templates/cart/index.html.twig （示例路径） #}
{% extends 'eshop_base.html.twig' %}

{% block title %}Your Cart - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('assets/eshop_styles/product-page.css') }}">
<link rel="stylesheet" href="{{ asset('assets/eshop_styles/cart.css') }}">

<h2>Your Shopping Cart</h2>

{% if cartItems is empty %}
  <p>Your cart is empty.</p>
{% else %}
  <table class="cart-table">
    <thead>
      <tr>
        <th>Product</th>
        {% if not shopInfo.hidePrices %}
          <th>Price</th>
        {% endif %}
        <th>Quantity</th>
        {% if not shopInfo.hidePrices %}
          <th>Total</th>
        {% endif %}
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
    {% for cartItem in cartItems %}
      {% set product = cartItem.getProduct() %}
      {% set price   = product.getPrice() %}
      {% set discount = product.getDiscount() %}
      {% set unitFinal = discount < 100 ? (price * discount / 100) : price %}
      {% set rowTotal  = unitFinal * cartItem.getQuantity() %}

      <tr>
        <td class="cart-item" data-label="Product">
          {% if product.getImageUrls() is not empty %}
            <img class="product-img"
                 src="{{ BMS_URL }}/images/{{ product.getImageUrls()|first }}"
                 alt="{{ product.getName() }}">
          {% endif %}
          {{ product.getName() }}
        </td>

        {% if not shopInfo.hidePrices %}
          <td data-label="Price">
            {% if discount < 100 %}
              <span class="original-price strikethrough">{{ money(price) }}</span><br>
              <span class="discounted-price">{{ money(unitFinal) }}</span>
              <span class="discount-tag">{{ 100 - discount }}% OFF</span>
            {% else %}
              {{ money(price) }}
            {% endif %}
          </td>
        {% endif %}

        <td data-label="Quantity">
          <div class="quantity-selector">
            <button class="quantity-btn"
                    onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() - 1 }})">-</button>
            <span class="quantity-value" id="cart-quantity-{{ cartItem.getId() }}">{{ cartItem.getQuantity() }}</span>
            <button class="quantity-btn"
                    onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() + 1 }})">+</button>
          </div>
        </td>

        {% if not shopInfo.hidePrices %}
          <td data-label="Total">
            {{ money(rowTotal) }}
          </td>
        {% endif %}

        <td data-label="Action">
          <button class="remove-btn" onclick="removeFromCart({{ cartItem.getId() }})">Remove</button>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if not shopInfo.hidePrices %}
    {% set total = 0 %}
    {% for item in cartItems %}
      {% set p = item.getProduct().getPrice() %}
      {% set d = item.getProduct().getDiscount() %}
      {% set unit = d < 100 ? (p * d / 100) : p %}
      {% set total = total + unit * item.getQuantity() %}
    {% endfor %}

    <div class="total-row">
      <p><strong>Total:</strong> {{ money(total) }}</p>
    </div>
  {% endif %}

  <div class="checkout-container">
    <button class="checkout-btn" onclick="goToDeliveryOption()">Proceed to Checkout</button>
  </div>
{% endif %}

{% if recommendations_enabled|default(true) and recommendedProducts is defined and recommendedProducts is not empty %}
  <section class="cart-recommendations">
    {% if cartItems is empty %}
      <h2>Recommended for you</h2>
    {% else %}
      <h2>You may also like</h2>
    {% endif %}

    <div class="recommended_products_grid">
      {% for product in recommendedProducts %}
        {% set imageUrls = product.getImageUrls() ?? [] %}
        {% set hasDiscount = product.discount is not null and product.discount < 100 %}
        {% set discountedRaw = (product.price * product.discount / 100) %}

        <a
          href="{{ path('show_eshop_product', {'id': product.id}) }}"
          class="product-card recommendation-link"
          data-page-type="cart"
          data-source-sku=""
          data-recommended-sku="{{ product.sku }}"
          data-algorithm="{{ cartItems is empty ? 'history_based' : 'session_based' }}"
          data-rank-position="{{ loop.index }}"
        >
          {% if imageUrls is not empty %}
            <img
              src="{{ imageUrls is not empty ? BMS_URL|default('') ~ '/images/' ~ imageUrls[0] : asset('images/fallback-product.png') }}"
              alt="{{ product.name }}"
              onerror="this.onerror=null;this.src='{{ asset('images/fallback-product.png') }}';"
            >
          {% else %}
            <img
              src="{{ asset('images/fallback-product.png') }}"
              alt="{{ product.name }}"
            >
          {% endif %}

          <div class="product-name">
            {{ product.getTranslatedName(locale|default('en')) }}
          </div>

          <div class="product-price">
            {% if hasDiscount %}
              <div class="original-price">
                <span class="strikethrough">{{ money(product.price) }}</span>
              </div>
              <div class="discounted-price">
                {{ money(discountedRaw) }}
              </div>
              <div class="discount-tag">{{ 100 - product.discount }}% OFF</div>
            {% else %}
              <div class="regular-price">{{ money(product.price) }}</div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}



<script src="{{ asset('assets/eshopCart.js') }}"></script>

{% if recommendation_logging_enabled|default(true) %}
<script>
document.addEventListener('click', function (event) {
    const link = event.target.closest('.recommendation-link');

    if (!link) {
        return;
    }

    const payload = {
        pageType: link.dataset.pageType || 'cart',
        sourceSku: link.dataset.sourceSku || null,
        recommendedSku: link.dataset.recommendedSku || '',
        algorithm: link.dataset.algorithm || 'unknown',
        rankPosition: parseInt(link.dataset.rankPosition || '0', 10),
        score: link.dataset.score ? parseFloat(link.dataset.score) : null,
        eventType: 'click'
    };

    if (!payload.recommendedSku) {
        return;
    }

    navigator.sendBeacon(
        '{{ path("recommendation_event_log") }}',
        new Blob([JSON.stringify(payload)], { type: 'application/json' })
    );
});
</script>
{% endif %}
{% endblock %}