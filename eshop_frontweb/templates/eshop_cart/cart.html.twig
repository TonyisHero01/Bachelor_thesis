{% extends 'eshop_base.html.twig' %}

{% block title %}Your Cart - {{ shopInfo.getEshopName() }}{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/product-page.css') }}">
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/cart.css') }}">

<h2>Your Shopping Cart</h2>

{% if cartItems is empty %}
    <p>Your cart is empty.</p>
{% else %}
    <table class="cart-table">
        <thead>
            <tr>
                <th>Product</th>
                {% if not shopInfo.hidePrices %}
                    <th>Price</th>
                {% endif %}
                <th>Quantity</th>
                {% if not shopInfo.hidePrices %}
                    <th>Total</th>
                {% endif %}
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for cartItem in cartItems %}
                <tr>
                    <td class="cart-item" data-label="Product">
                    {% if cartItem.getProduct().getImageUrls() is not empty %}
                        <img class="product-img" src="{{ BMS_URL }}/images/{{ cartItem.getProduct().getImageUrls()|first }}" alt="{{ cartItem.getProduct().getName() }}" class="cart-product-image">
                    {% endif %}
                    {{ cartItem.getProduct().getName() }}
                    </td>
                    {% if not shopInfo.hidePrices %}
                        <td data-label="Price">
                            {% set discount = cartItem.getProduct().getDiscount() %}
                            {% set price = cartItem.getProduct().getPrice() %}
                            {% set currency = cartItem.getProduct().getCurrency().getName() %}
                            {% if discount < 100 %}
                                <span class="original-price strikethrough">{{ price }} {{ currency }}</span><br>
                                <span class="discounted-price">{{ (price * discount / 100) | number_format(2, '.', '') }} {{ currency }}</span>
                            {% else %}
                                {{ price }} {{ currency }}
                            {% endif %}
                        </td>
                    {% endif %}
                    <td data-label="Quantity">
                        <div class="quantity-selector">
                            <button class="quantity-btn" onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() - 1 }})">-</button>
                            <span class="quantity-value" id="cart-quantity-{{ cartItem.getId() }}">{{ cartItem.getQuantity() }}</span>
                            <button class="quantity-btn" onclick="updateCart({{ cartItem.getId() }}, {{ cartItem.getQuantity() + 1 }})">+</button>
                        </div>
                    </td>
                    {% if not shopInfo.hidePrices %}
                        <td data-label="Total">
                            {% set discount = cartItem.getProduct().getDiscount() %}
                            {% set price = cartItem.getProduct().getPrice() %}
                            {% set discounted = discount < 100 ? (price * discount / 100) : price %}
                            {{ (cartItem.getQuantity() * discounted) | number_format(2, '.', '') }}
                        </td>
                    {% endif %}
                    <td data-label="Action">
                        <button class="remove-btn" onclick="removeFromCart({{ cartItem.getId() }})">Remove</button>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    
    {% if not shopInfo.hidePrices %}
        <div class="total-row">
            {% set total = 0 %}
            {% for item in cartItems %}
                {% set discount = item.getProduct().getDiscount() %}
                {% set price = item.getProduct().getPrice() %}
                {% set discounted = discount < 100 ? (price * discount / 100) : price %}
                {% set total = total + discounted * item.getQuantity() %}
            {% endfor %}
            <p><strong>Total:</strong> {{ total | number_format(2, '.', '') }} {{ cartItems[0].getProduct().getCurrency().getName() }}</p>
        </div>
    {% endif %}
    
    <div class="checkout-container">
        <button class="checkout-btn" onclick="goToDeliveryOption()">Proceed to Checkout</button>
    </div>
{% endif %}
<script src="{{ asset('../assets/eshopCart.js') }}"></script>
{% endblock %}