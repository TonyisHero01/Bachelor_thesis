{% extends 'eshop_base.html.twig' %}

{% block title %}Customer Registration{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('assets/eshop_styles/register.css') }}">
    <div class="registration-container">
        <h1>📝 Create Your Account</h1>

        <p class="subtitle">Join us and enjoy a better shopping experience.</p>

        <div class="registration-form">
            {{ form_start(registrationForm) }}

                <div class="form-group">
                    {{ form_label(registrationForm.email) }}
                    {{ form_widget(registrationForm.email, { 'attr': {'placeholder': 'Enter your email'} }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.first) }}
                    {{ form_widget(registrationForm.plainPassword.first, {
                        'attr': {'placeholder': 'Create a password'}
                    }) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.second) }}
                    {{ form_widget(registrationForm.plainPassword.second, {
                        'attr': {'placeholder': 'Repeat password'}
                    }) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-primary">Register</button>
                    <button type="button" class="btn btn-secondary" onclick="history.back()">Cancel</button>
                </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}