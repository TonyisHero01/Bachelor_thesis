{% extends 'eshop_base.html.twig' %}

{% block title %}My Return Requests{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/eshop_styles/customer_home.css') }}">

<div class="customer-container">
    <h2>My Return Requests</h2>

    {% if returnRequests is empty %}
        <p>You have no return requests.</p>
    {% else %}
        <table class="styled-table">
            <thead>
                <tr>
                    <th>Request ID</th>
                    <th>Order ID</th>
                    <th>Return Reason</th>
                    <th>Products (SKUs)</th>
                    <th>Status</th>
                    <th>Request Date</th>
                </tr>
            </thead>
            <tbody>
                {% for request in returnRequests %}
                    <tr class="status-{{ request.getStatus() }}">
                        <td>{{ request.getId() }}</td>
                        <td>{{ request.getOrder().getId() }}</td>
                        <td>{{ request.getReturnReason() ?: 'N/A' }}</td>
                        <td>{{ request.getProductSkus() }}</td>
                        <td>{{ request.getStatus()|capitalize }}</td>
                        <td>{{ request.getRequestDate().format('Y-m-d H:i') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

<style>
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        margin: 25px 0;
        font-size: 18px;
        text-align: left;
    }

    .styled-table th, .styled-table td {
        padding: 12px 15px;
        border: 1px solid #ddd;
    }

    .styled-table thead tr {
        background-color: #009879;
        color: #ffffff;
        text-align: left;
    }

    .status-pending {
        background-color: white; /* 白色 */
    }

    .status-accepted {
        background-color: #c3e6cb; /* 绿色 */
    }

    .status-rejected {
        background-color: #f5c6cb; /* 红色 */
    }
</style>

{% endblock %}