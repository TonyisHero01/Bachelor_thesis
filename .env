#########################################
# Shared environment configuration
# Used by:
#   - eshop_bms
#   - eshop_frontweb
#########################################

#########################################
# Symfony Core
#########################################

APP_ENV=dev

#########################################
# Database (PostgreSQL shared)
#########################################

# IMPORTANT: Configure serverVersion in doctrine.yaml if needed
DATABASE_URL="postgresql://user:password@db:5432/app"

#########################################
# External Services
#########################################

# Python search API (used by BMS / frontweb search)
PYTHON_API_BASE_URL=http://python-api:8000

# Mailer (shared SMTP)
MAILER_DSN=null://null
# Example:
# MAILER_DSN=smtp://user:pass@smtp.gmail.com:587

#########################################
# Application Limits
#########################################

MAX_ARTICLES_COUNT_PER_PAGE=10
NAME_MAX_LENGTH=32
CONTENT_MAX_LENGTH=1024

#########################################
# CORS (for local development)
#########################################

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

#########################################
# BMS URL (used by frontweb for redirects)
#########################################

BMS_URL="http://localhost:8083/"

#########################################
# Lock mechanism
#########################################

# For multi-container production, consider:
# postgresql+advisory://user:password@db/app
LOCK_DSN=flock

#########################################
# Optional Future Extensions
#########################################

# REDIS_URL=redis://redis:6379
# ELASTICSEARCH_URL=http://elasticsearch:9200