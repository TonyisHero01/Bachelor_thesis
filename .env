# =========================
# Docker images
# =========================
GHCR_NAMESPACE=ghcr.io/tonyishero01
IMAGE_TAG=latest

# =========================
# Symfony
# =========================
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=75d2222c239930c8fc40c98ae6b88cb6d9dfacf51c5c8c0749583fc681de9d9a

# =========================
# Database
# =========================
DATABASE_URL=postgresql://user:password@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# =========================
# Python API
# =========================
PYTHON_API_BASE_URL=http://python-api:8000

# =========================
# Mail
# =========================
MAILER_DSN=smtp://<user>:<password>@<host>:<port>?encryption=tls

# =========================
# App config
# =========================
MAX_ARTICLES_COUNT_PER_PAGE=10
NAME_MAX_LENGTH=32
CONTENT_MAX_LENGTH=1024

# =========================
# CORS / URLs
# =========================
CORS_ALLOW_ORIGIN=^https?://(localhost|127\\.0\\.0\\.1)(:[0-9]+)?$
BMS_URL=http://localhost:8083/

# =========================
# Symfony Lock
# =========================
LOCK_DSN=flock