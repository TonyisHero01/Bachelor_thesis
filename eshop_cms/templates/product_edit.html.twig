<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Product List</title>
    <link rel="stylesheet" href="{{ asset('../assets/styles/app.css') }}">
</head>
<body>
    <h1>Product Edit</h1>
    <div id=productId product-id-data={{ product.id }}></div>
    <div id="routeData" data-product_list-route="{{ path('show_All_products') }}"></div>
    <div id="body">
    
    <form action="#"  enctype="multipart/form-data">

        <label for="name">Name</label>
        <input type="text" id="name" name="name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ product.name }}"><br>
        <p id="last modified">Added time: </p>
        <p id="add_time">{{ product.addTime }}</p>
        <label for="categoryOptions">Choose Category:</label><br>
        <select id="categoryOptions" name="categoryOptions">
            {% for category in categories %}
                <option value="{{ category.id }}" {% if category.name == product.kategory %}selected{% endif %}>{{category.name}}</option>
            {% endfor %}
        </select><br>
        <label for="description">Description</label><br>
        <textarea id="description" name="description" rows="15" value="{{ product.description }}">{{ product.description }}</textarea><br>
        <label for="number_in_stock">Number in stock</label><br>
        <input type="text" id="number_in_stock" name="numberInStock" value="{{ product.numberInStock }}"><br>
        <label for="image_urls">Images</label><br>
        <div id="image_container">
            {% if product.imageUrls is not empty %}
                {% for imageUrl in product.imageUrls %}
                    <div class="image_upload_section" data-image-url="{{imageUrl}}">
                        <img id="image" src="{{ asset('images/' ~ imageUrl) }}" alt="{{ product.name }}" width="304" height="228"><br>
                        <button type="button" class="delete-button" onclick="deleteImage('{{ imageUrl }}')">删除图片</button>
                    </div>
                {% endfor %}
            {% else %}
                <div class="image_upload_section">
                    <p>No images uploaded yet</p>
                </div>
            {% endif %}
            <input class="image_upload_input" type="file" multiple>
            <input type="hidden" class="image_path" value="">
        </div>
        <label for="width">Width</label><br>
        <input type="number" id="width" name="width" value="{{ product.width }}" step="0.01" min="0"><br>
        <label for="height">Height</label>
        <input type="number" id="height" name="height" value="{{ product.height }}" step="0.01" min="0">
        <label for="length">Length</label>
        <input type="number" id="length" name="length" value="{{ product.length }}" step="0.01" min="0"><br>
        <label for="weight">Weight</label>
        <input type="number" id="weight" name="weight" value="{{ product.weight }}" step="0.01" min="0"><br>
        <label for="material">Material</label>
        <input type="text" id="material" name="material" value="{{ product.material }}"><br>
        <label for="color">Color</label>
        <input type="text" id="color" name="color" value="{{ product.color }}"><br>
        <label for="price">Price</label>
        <input type="number" id="price" name="price" value="{{ product.price }}" step="0.01" min="0"><br>
        <label for="discount">Discount</label>
        <input type="number" id="discount" name="discount" value="{{ product.discount }}" step="0.01" min="0"><br>
        <label for="hideBox">
            <input type="checkbox" id="hideBox" name="hideBox" {% if product.hidden %}checked{% endif %}> Hide Product
        </label><br>
        <div class="buttons">
        <button type="button" id="saveButton" onclick="save_()">Save</button>
        <button type="button" id="backButton" onclick="backToProducts()">Back to products</button>
        <script src="{{ asset('../assets/edit.js') }}"></script>
    </form>
    </div>
</body>
</html>