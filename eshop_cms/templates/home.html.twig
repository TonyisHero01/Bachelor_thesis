<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Home</title>
        <link rel="stylesheet" href="{{ asset('../assets/styles/app.css') }}">
    </head>
    <body>
        <div class="content">
            Hello {{ app.user.name ?: '' }} {{ app.user.surname ?: '' }}
            <br>
            <a href="/{{ app.user ? 'logout' : 'login' }}">{{ app.user ? 'Logout' : 'Login' }}</a>
            {% if 'ROLE_SUPER_ADMIN' in roles %}
                <form action="#"  enctype="multipart/form-data">

                    <label for="eshop_name">Eshop Name</label>
                    <input type="text" id="eshop_name" name="eshop_name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.eshopName }}"><br>
                    <label for="company_name">Comapny Name</label>
                    <input type="text" id="company_name" name="company_name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.companyName }}"><br>
                    <label for="cin">CIN Number</label>
                    <input type="text" id="cin" name="cin" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.cin }}"><br>
                    <label for="address">Address</label>
                    <input type="text" id="address" name="address" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.address }}"><br>
                    <label for="tel">Telephone</label>
                    <input type="text" id="tel" name="tel" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.telephone }}"><br>
                    <label for="email">Email</label>
                    <input type="text" id="email" name="email" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.email }}"><br>
                    <label for="about">About Us</label><br>
                    <textarea id="about" name="about" rows="15" value="{{ shopInfo.aboutUs }}">{{ shopInfo.aboutUs }}</textarea><br>
                    <label for="how_to_order">How to order</label><br>
                    <textarea id="how_to_order" name="how_to_order" rows="15" value="{{ shopInfo.howToOrder }}">{{ shopInfo.howToOrder }}</textarea><br>
                    <label for="conditions">Business Conditions</label><br>
                    <textarea id="conditions" name="conditions" rows="15" value="{{ shopInfo.businessConditions }}">{{ shopInfo.businessConditions }}</textarea><br>
                    <label for="privacy">Privacy policy</label><br>
                    <textarea id="privacy" name="privacy" rows="15" value="{{ shopInfo.privacyPolicy }}">{{ shopInfo.privacyPolicy }}</textarea><br>
                    <label for="shipping">Shipping Info</label><br>
                    <textarea id="shipping" name="shipping" rows="15" value="{{ shopInfo.shippingInfo }}">{{ shopInfo.shippingInfo }}</textarea><br>
                    <label for="payment">Payment</label><br>
                    <textarea id="payment" name="payment" rows="15" value="{{ shopInfo.payment }}">{{ shopInfo.payment }}</textarea><br>
                    <label for="refund">Refund</label><br>
                    <textarea id="refund" name="refund" rows="15" value="{{ shopInfo.refund }}">{{ shopInfo.refund }}</textarea><br>
                    <h2>ESHOP STYLES</h2>
                    <label for="color">Color Code</label>
                    <input type="text" id="color" name="color" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.colorCode }}"><br>
                    
                    <label for="logo_url">LOGO</label><br>
                    <img id="logo_preview" src="{{ shopInfo.logo ? asset('images/' ~ shopInfo.logo) : '' }}" alt="Logo" width="304" height="228"><br>
                    <input id="logo_url" type="file" accept="image/*" onchange="handleLogoUpload(event)">
                    <input type="hidden" id="logo_path" value="{{ shopInfo.logo }}">
                    
                    <label for="carousel_urls">Carousel pictures</label><br>
                    
                    <div id="image_container">
                        {% if shopInfo.carouselPictures is not empty %}
                            {% for imageUrl in shopInfo.carouselPictures %}
                                <div class="image_upload_section" data-image-url="{{imageUrl}}">
                                    <img id="image" src="{{ asset('images/' ~ imageUrl) }}" alt="{{ shopInfo.eshopName }}" width="304" height="228"><br>
                                    <button type="button" class="delete-button" onclick="deleteImage('{{ imageUrl }}')">删除图片</button>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="image_upload_section">
                                <p>No images uploaded yet</p>
                            </div>
                        {% endif %}
                        <input class="image_upload_input" type="file" multiple>
                        <input type="hidden" class="image_path" value="">
                    </div>
                    
                    <div class="buttons">
                    <button type="button" id="saveButton" onclick="save_()">Save</button>
                    <button type="button" id="backButton" onclick="discard()">Discard Changes</button>
                    <script src="{{ asset('../assets/eshopEdit.js') }}"></script>
                </form>
            {% endif %}
        </div>
        <div class="sidebar">
            <h3>Your Roles</h3>
            <ul>
                {% if 'ROLE_SUPER_ADMIN' in roles %}
                    <li><a href='{{ path('show_All_admins') }}'>{{ 'SUPER ADMIN' }}</a></li>
                {% endif %}

                {# 判断是否显示 ROLE_ADMIN #}
                {% if 'ROLE_ADMIN' in roles %}
                    <li><a href='{{ path('show_All_employees') }}'>{{ 'ADMINISTRATOR' }}</a></li>
                {% endif %}

                {# 判断是否显示 ROLE_WAREHOUSEMAN #}
                {% if 'ROLE_WAREHOUSEMAN' in roles %}
                    <li>{{ 'WAREHOUSEMAN' }}</li>
                {% endif %}

                {# 判断是否显示 ROLE_WAREHOUSE_MANAGER #}
                {% if 'ROLE_WAREHOUSE_MANAGER' in roles %}
                    <li><a href='{{ path('show_All_products') }}' >{{ 'WAREHOUSE MANAGER' }}</a></li>
                {% endif %}

                {# 判断是否显示 ROLE_TRANSLATOR #}
                {% if 'ROLE_TRANSLATOR' in roles %}
                    <li>{{ 'TRANSLATOR' }}</li>
                {% endif %}

                {# 判断是否显示 ROLE_EVENT_MANAGER #}
                {% if 'ROLE_EVENT_MANAGER' in roles %}
                    <li>{{ 'EVENT MANAGER' }}</li>
                {% endif %}

                {# 判断是否显示 ROLE_ACCOUNTING #}
                {% if 'ROLE_ACCOUNTING' in roles %}
                    <li>{{ 'ACCOUNTING' }}</li>
                {% endif %}
            </ul>
        </div>
    </body>
</html>
