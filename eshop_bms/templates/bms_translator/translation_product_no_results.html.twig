{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>BMS Translation - No Result Page</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    h2 { font-size: 20px; color: #444; margin-top: 2em; }
    .field-group { margin-bottom: 1.2em; }
    label { display: block; font-weight: bold; margin-bottom: 0.3em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.3em;
    }
    button {
      padding: 0.6em 1.4em;
      font-size: 1em;
      cursor: pointer;
      margin-top: 1em;
    }
  </style>
</head>
<body>

  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Translate No Results Page</h1>

    <input type="hidden" name="target_language" value="{{ lang }}">
    <input type="hidden" name="original_path" value="templates/product/no_results.html.twig">

    <div class="field-group">
      <label>No result Found</label>
      <input type="text" name="field__no_result" placeholder="No result Found">
      <input type="hidden" name="original__no_result" value="No result Found">
    </div>

    <div class="field-group">
      <label>Done</label>
      <input type="text" name="field__done" placeholder="Done">
      <input type="hidden" name="original__done" value="Done">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}