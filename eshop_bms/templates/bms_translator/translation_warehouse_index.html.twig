{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translate: Warehouse</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 1.5em; margin-bottom: 1em; }
    h2 { font-size: 1.2em; margin-top: 2em; color: #444; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"] { width: 100%; padding: 0.5em; }
    button { margin-top: 2em; padding: 0.6em 1.2em; font-size: 1em; cursor: pointer; }
  </style>
</head>
<body>

  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Translate: Warehouse</h1>

    <input type="hidden" name="target_language" value="{{ lang }}">
    <input type="hidden" name="original_path" value="templates/warehouse/index.html.twig">

    <h2>Static Text</h2>

    {% set fields = {
      'order_tracking': 'Order Tracking',
      'return_requests': 'Return Requests'
    } %}

    {% for name, original in fields %}
      <div class="field-group">
        <label>{{ original }}</label>
        <input type="text" name="field__{{ name }}" placeholder="{{ original }}">
        <input type="hidden" name="original__{{ name }}" value="{{ original }}">
      </div>
    {% endfor %}

    <button type="submit">Generate Translated File</button>
  </form>

</body>
</html>
{% endblock %}