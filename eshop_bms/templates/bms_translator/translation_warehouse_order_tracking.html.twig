{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translation - Track Order</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.5em;
    }
    button {
      margin-top: 2em;
      padding: 0.6em 1.2em;
      font-size: 1em;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <input type="hidden" name="original_path" value="templates/warehouse/order_tracking.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <h2>Track Order Page</h2>

    <div class="field-group">
      <label>Track Order</label>
      <input type="text" name="field__track_order_title" placeholder="Track Order">
      <input type="hidden" name="original__track_order_title" value="Track Order">
    </div>

    <div class="field-group">
      <label>Customer Email</label>
      <input type="text" name="field__customer_email" placeholder="Customer Email">
      <input type="hidden" name="original__customer_email" value="Customer Email">
    </div>

    <div class="field-group">
      <label>Order ID</label>
      <input type="text" name="field__order_id" placeholder="Order ID">
      <input type="hidden" name="original__order_id" value="Order ID">
    </div>

    <div class="field-group">
      <label>Price</label>
      <input type="text" name="field__price" placeholder="Price">
      <input type="hidden" name="original__price" value="Price">
    </div>

    <div class="field-group">
      <label>Action</label>
      <input type="text" name="field__action" placeholder="Action">
      <input type="hidden" name="original__action" value="Action">
    </div>

    <div class="field-group">
      <label>View Details</label>
      <input type="text" name="field__view_details_button" placeholder="View Details">
      <input type="hidden" name="original__view_details_button" value="View Details">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}