{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translate: Employee Edit</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 1.5em; margin-bottom: 1em; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"] { width: 100%; padding: 0.5em; }
    button { margin-top: 2em; padding: 0.6em 1.2em; font-size: 1em; cursor: pointer; }
  </style>
</head>
<body>

  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Translate: Employee Edit</h1>
    <input type="hidden" name="original_path" value="templates/admin/employee_edit.html.twig">
    <input type="hidden" name="target_language" value="{{ lang|default('CZ') }}">

    <div class="field-group">
      <label>Employee Edit Title</label>
      <input type="text" name="field__employee_edit_title" placeholder="Employee Edit">
      <input type="hidden" name="original__employee_edit_title" value="Employee Edit">
    </div>

    <div class="field-group">
      <label>Surname</label>
      <input type="text" name="field__surname" placeholder="Surname">
      <input type="hidden" name="original__surname" value="Surname">
    </div>

    <div class="field-group">
      <label>Name</label>
      <input type="text" name="field__name" placeholder="Name">
      <input type="hidden" name="original__name" value="Name">
    </div>

    <div class="field-group">
      <label>Username</label>
      <input type="text" name="field__username" placeholder="Username">
      <input type="hidden" name="original__username" value="Username">
    </div>

    <div class="field-group">
      <label>Phone Number</label>
      <input type="text" name="field__phone_number" placeholder="Phone Number">
      <input type="hidden" name="original__phone_number" value="Phone Number">
    </div>

    <div class="field-group">
      <label>Email</label>
      <input type="text" name="field__email" placeholder="Email">
      <input type="hidden" name="original__email" value="Email">
    </div>

    <div class="field-group">
      <label>Choose Employee's Positions</label>
      <input type="text" name="field__roles_legend" placeholder="Choose Employee's Positions">
      <input type="hidden" name="original__roles_legend" value="Choose Employee's Positions">
    </div>

    <div class="field-group">
      <label>Warehouseman</label>
      <input type="text" name="field__warehouseman" placeholder="Warehouseman">
      <input type="hidden" name="original__warehouseman" value="Warehouseman">
    </div>

    <div class="field-group">
      <label>Warehouse Manager</label>
      <input type="text" name="field__warehouse_manager" placeholder="Warehouse Manager">
      <input type="hidden" name="original__warehouse_manager" value="Warehouse Manager">
    </div>

    <div class="field-group">
      <label>Translator</label>
      <input type="text" name="field__translator" placeholder="Translator">
      <input type="hidden" name="original__translator" value="Translator">
    </div>

    <div class="field-group">
      <label>Event Manager</label>
      <input type="text" name="field__event_manager" placeholder="Event Manager">
      <input type="hidden" name="original__event_manager" value="Event Manager">
    </div>

    <div class="field-group">
      <label>Accounting</label>
      <input type="text" name="field__accounting" placeholder="Accounting">
      <input type="hidden" name="original__accounting" value="Accounting">
    </div>

    <div class="field-group">
      <label>Administrator</label>
      <input type="text" name="field__admin" placeholder="Administrator">
      <input type="hidden" name="original__admin" value="Administrator">
    </div>

    <div class="field-group">
      <label>Save</label>
      <input type="text" name="field__save" placeholder="Save">
      <input type="hidden" name="original__save" value="Save">
    </div>

    <div class="field-group">
      <label>Back to Employees</label>
      <input type="text" name="field__back" placeholder="Back to Employees">
      <input type="hidden" name="original__back" value="Back to Employees">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}