{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translate: Order Detail</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 1.5em; margin-bottom: 1em; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"] { width: 100%; padding: 0.5em; }
    button { margin-top: 2em; padding: 0.6em 1.2em; font-size: 1em; cursor: pointer; }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Translate: Order Detail</h1>
    <input type="hidden" name="original_path" value="templates/accounting/order_detail.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
      <label>Order</label>
      <input type="text" name="field__order" placeholder="Order">
      <input type="hidden" name="original__order" value="Order">
    </div>

    <div class="field-group">
      <label>Detail</label>
      <input type="text" name="field__detail" placeholder="Detail">
      <input type="hidden" name="original__detail" value="Detail">
    </div>

    <div class="field-group">
      <label>Email</label>
      <input type="text" name="field__email" placeholder="Email:">
      <input type="hidden" name="original__email" value="Email:">
    </div>

    <div class="field-group">
      <label>Contact</label>
      <input type="text" name="field__contact" placeholder="Contact:">
      <input type="hidden" name="original__contact" value="Contact:">
    </div>

    <div class="field-group">
      <label>Created At</label>
      <input type="text" name="field__created_at" placeholder="Created At:">
      <input type="hidden" name="original__created_at" value="Created At:">
    </div>

    <div class="field-group">
      <label>Total</label>
      <input type="text" name="field__total" placeholder="Total:">
      <input type="hidden" name="original__total" value="Total:">
    </div>

    <div class="field-group">
      <label>Order Items</label>
      <input type="text" name="field__order_items" placeholder="Order Items:">
      <input type="hidden" name="original__order_items" value="Order Items:">
    </div>

    <div class="field-group">
      <label>Download PDF</label>
      <input type="text" name="field__download_pdf" placeholder="Download PDF">
      <input type="hidden" name="original__download_pdf" value="Download PDF">
    </div>

    <div class="field-group">
      <label>Send Invoice by Email</label>
      <input type="text" name="field__send_invoice" placeholder="Send Invoice by Email">
      <input type="hidden" name="original__send_invoice" value="Send Invoice by Email">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}