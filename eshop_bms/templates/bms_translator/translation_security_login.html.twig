{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translation - Login Page</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1.2em; }
    label { display: block; font-weight: bold; margin-bottom: 0.3em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.3em;
    }
    button {
      padding: 0.6em 1.4em;
      font-size: 1em;
      cursor: pointer;
      margin-top: 1.5em;
    }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Translate: Login Page</h1>
    <input type="hidden" name="original_path" value="templates/security/login.html.twig">
    <input type="hidden" name="target_language" value="{{ lang|default('CZ') }}">

    

    <div class="field-group">
      <label>Please sign in</label>
      <input type="hidden" name="original__please_sign_in" value="Please sign in">
      <input type="text" name="field__please_sign_in" placeholder="Please sign in">
    </div>

    <div class="field-group">
      <label>Email</label>
      <input type="hidden" name="original__email" value="Email">
      <input type="text" name="field__email" placeholder="Email">
    </div>

    <div class="field-group">
      <label>Password</label>
      <input type="hidden" name="original__password" value="Password">
      <input type="text" name="field__password" placeholder="Password">
    </div>

    <div class="field-group">
      <label>Sign in</label>
      <input type="hidden" name="original__sign_in" value="Sign in">
      <input type="text" name="field__sign_in" placeholder="Sign in">
    </div>

    <div class="field-group">
      <label>Login Error Message (optional)</label>
      <input type="hidden" name="original__login_error_message" value="Invalid credentials.">
      <input type="text" name="field__login_error_message" placeholder="e.g. Invalid credentials.">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}