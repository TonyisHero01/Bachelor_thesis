{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translate – Return Requests List</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.5em;
    }
    button {
      margin-top: 2em;
      padding: 0.6em 1.2em;
      font-size: 1em;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Return Requests Page</h1>
    <input type="hidden" name="original_path" value="templates/warehouse/return_requests.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
      <label>Return Requests</label>
      <input type="hidden" name="original__return_requests" value="Return Requests">
      <input type="text" name="field__return_requests" placeholder="Return Requests">
    </div>

    <div class="field-group">
      <label>No return requests found.</label>
      <input type="hidden" name="original__no_requests" value="No return requests found.">
      <input type="text" name="field__no_requests" placeholder="No return requests found.">
    </div>

    <div class="field-group">
      <label>ID</label>
      <input type="hidden" name="original__id" value="ID">
      <input type="text" name="field__id" placeholder="ID">
    </div>

    <div class="field-group">
      <label>Order ID</label>
      <input type="hidden" name="original__order_id" value="Order ID">
      <input type="text" name="field__order_id" placeholder="Order ID">
    </div>

    <div class="field-group">
      <label>Customer Name</label>
      <input type="hidden" name="original__customer_name" value="Customer Name">
      <input type="text" name="field__customer_name" placeholder="Customer Name">
    </div>

    <div class="field-group">
      <label>Email</label>
      <input type="hidden" name="original__email" value="Email">
      <input type="text" name="field__email" placeholder="Email">
    </div>

    <div class="field-group">
      <label>Phone</label>
      <input type="hidden" name="original__phone" value="Phone">
      <input type="text" name="field__phone" placeholder="Phone">
    </div>

    <div class="field-group">
      <label>Return Reason</label>
      <input type="hidden" name="original__return_reason" value="Return Reason">
      <input type="text" name="field__return_reason" placeholder="Return Reason">
    </div>

    <div class="field-group">
      <label>Products (SKUs)</label>
      <input type="hidden" name="original__skus" value="Products (SKUs)">
      <input type="text" name="field__skus" placeholder="Products (SKUs)">
    </div>

    <div class="field-group">
      <label>Request Date</label>
      <input type="hidden" name="original__request_date" value="Request Date">
      <input type="text" name="field__request_date" placeholder="Request Date">
    </div>

    <div class="field-group">
      <label>Status</label>
      <input type="hidden" name="original__status" value="Status">
      <input type="text" name="field__status" placeholder="Status">
    </div>

    <div class="field-group">
      <label>View Details</label>
      <input type="hidden" name="original__view_details" value="View Details">
      <input type="text" name="field__view_details" placeholder="View Details">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}