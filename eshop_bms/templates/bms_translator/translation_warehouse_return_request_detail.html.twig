{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translate – Return Request Details</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1em; }
    label { display: block; font-weight: bold; margin-bottom: 0.2em; }
    input[type="text"], textarea {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.5em;
    }
    button {
      margin-top: 2em;
      padding: 0.6em 1.2em;
      font-size: 1em;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Return Request Page</h1>
    <input type="hidden" name="original_path" value="templates/warehouse/return_request_detail.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
      <label>Return Request #</label>
      <input type="text" name="field__title" placeholder="Return Request #">
      <input type="hidden" name="original__title" value="Return Request #">
    </div>

    <div class="field-group"><label>Order ID</label>
      <input type="text" name="field__order_id" placeholder="Order ID">
      <input type="hidden" name="original__order_id" value="Order ID">
    </div>
    <div class="field-group"><label>Customer Name</label>
      <input type="text" name="field__customer_name" placeholder="Customer Name">
      <input type="hidden" name="original__customer_name" value="Customer Name">
    </div>
    <div class="field-group"><label>Email</label>
      <input type="text" name="field__email" placeholder="Email">
      <input type="hidden" name="original__email" value="Email">
    </div>
    <div class="field-group"><label>Phone</label>
      <input type="text" name="field__phone" placeholder="Phone">
      <input type="hidden" name="original__phone" value="Phone">
    </div>
    <div class="field-group"><label>Return Reason</label>
      <input type="text" name="field__reason" placeholder="Return Reason">
      <input type="hidden" name="original__reason" value="Return Reason">
    </div>
    <div class="field-group"><label>Products (SKUs)</label>
      <input type="text" name="field__skus" placeholder="Products (SKUs)">
      <input type="hidden" name="original__skus" value="Products (SKUs)">
    </div>
    <div class="field-group"><label>Request Date</label>
      <input type="text" name="field__date" placeholder="Request Date">
      <input type="hidden" name="original__date" value="Request Date">
    </div>
    <div class="field-group"><label>Message</label>
      <input type="text" name="field__message" placeholder="Message">
      <input type="hidden" name="original__message" value="Message">
    </div>
    <div class="field-group"><label>Accept</label>
      <input type="text" name="field__accept_button" placeholder="Accept">
      <input type="hidden" name="original__accept_button" value="Accept">
    </div>
    <div class="field-group"><label>Reject</label>
      <input type="text" name="field__reject_button" placeholder="Reject">
      <input type="hidden" name="original__reject_button" value="Reject">
    </div>
    <div class="field-group"><label>Back to Return Requests</label>
      <input type="text" name="field__back_button" placeholder="Back to Return Requests">
      <input type="hidden" name="original__back_button" value="Back to Return Requests">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}