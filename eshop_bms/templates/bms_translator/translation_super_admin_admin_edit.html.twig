{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translation - Admin Edit</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1.2em; }
    label { display: block; font-weight: bold; margin-bottom: 0.3em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.3em;
    }
    button {
      padding: 0.6em 1.4em;
      font-size: 1em;
      cursor: pointer;
      margin-top: 1.5em;
    }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <h2>Admin Edit Page</h2>
    <input type="hidden" name="original_path" value="templates/super_admin/admin_edit.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group"><label>Admin Edit</label>
      <input type="text" placeholder="Admin Edit" name="field__admin_edit_title">
      <input type="hidden" name="original__admin_edit_title" value="Admin Edit">
    </div>
    <div class="field-group"><label>Surname</label>
      <input type="text" placeholder="Surname" name="field__surname">
      <input type="hidden" name="original__surname" value="Surname">
    </div>
    <div class="field-group"><label>Name</label>
      <input type="text" placeholder="Name" name="field__name">
      <input type="hidden" name="original__name" value="Name">
    </div>
    <div class="field-group"><label>Username</label>
      <input type="text" placeholder="Username" name="field__username">
      <input type="hidden" name="original__username" value="Username">
    </div>
    <div class="field-group"><label>Phone Number</label>
      <input type="text" placeholder="Phone Number" name="field__phone_number">
      <input type="hidden" name="original__phone_number" value="Phone Number">
    </div>
    <div class="field-group"><label>Email</label>
      <input type="text" placeholder="Email" name="field__email">
      <input type="hidden" name="original__email" value="Email">
    </div>

    <h3>Roles</h3>
    <div class="field-group"><label>Choose Employee's Positions</label>
      <input type="text" placeholder="Choose Employee's Positions" name="field__legend_roles">
      <input type="hidden" name="original__legend_roles" value="Choose Employee's Positions">
    </div>
    <div class="field-group"><label>Warehouseman</label>
      <input type="text" placeholder="Warehouseman" name="field__role_warehouseman">
      <input type="hidden" name="original__role_warehouseman" value="Warehouseman">
    </div>
    <div class="field-group"><label>Warehouse Manager</label>
      <input type="text" placeholder="Warehouse Manager" name="field__role_warehouse_manager">
      <input type="hidden" name="original__role_warehouse_manager" value="Warehouse Manager">
    </div>
    <div class="field-group"><label>Translator</label>
      <input type="text" placeholder="Translator" name="field__role_translator">
      <input type="hidden" name="original__role_translator" value="Translator">
    </div>
    <div class="field-group"><label>Event Manager</label>
      <input type="text" placeholder="Event Manager" name="field__role_event_manager">
      <input type="hidden" name="original__role_event_manager" value="Event Manager">
    </div>
    <div class="field-group"><label>Accounting</label>
      <input type="text" placeholder="Accounting" name="field__role_accounting">
      <input type="hidden" name="original__role_accounting" value="Accounting">
    </div>
    <div class="field-group"><label>Administrator</label>
      <input type="text" placeholder="Administrator" name="field__role_admin">
      <input type="hidden" name="original__role_admin" value="Administrator">
    </div>

    <h3>Buttons</h3>
    <div class="field-group"><label>Save</label>
      <input type="text" placeholder="Save" name="field__save_button">
      <input type="hidden" name="original__save_button" value="Save">
    </div>
    <div class="field-group"><label>Back to Admins</label>
      <input type="text" placeholder="Back to Admins" name="field__back_button">
      <input type="hidden" name="original__back_button" value="Back to Admins">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}