{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Translation - Employee Registration</title>
  <style>
    body { font-family: sans-serif; padding: 2em; }
    h1 { font-size: 24px; margin-bottom: 1em; }
    .field-group { margin-bottom: 1.2em; }
    label { display: block; font-weight: bold; margin-bottom: 0.3em; }
    input[type="text"] {
      width: 100%;
      padding: 0.5em;
      margin-bottom: 0.3em;
    }
    button {
      padding: 0.6em 1.4em;
      font-size: 1em;
      cursor: pointer;
      margin-top: 1.5em;
    }
  </style>
</head>
<body>
  <form id="translationForm" method="post" action="/translation/submit">
    <h1>Employee Registration Page</h1>
    <input type="hidden" name="target_language" value="{{ lang }}">
    <input type="hidden" name="original_path" value="templates/registration/register.html.twig">

    <div class="field-group">
      <label>Employee Registration</label>
      <input type="hidden" name="original__employee_registration" value="Employee Registration">
      <input type="text" name="field__employee_registration" placeholder="Employee Registration">
    </div>

    <div class="field-group">
      <label>Surname</label>
      <input type="hidden" name="original__surname" value="Surname">
      <input type="text" name="field__surname" placeholder="Surname">
    </div>

    <div class="field-group">
      <label>Name</label>
      <input type="hidden" name="original__name" value="Name">
      <input type="text" name="field__name" placeholder="Name">
    </div>

    <div class="field-group">
      <label>Username</label>
      <input type="hidden" name="original__username" value="Username">
      <input type="text" name="field__username" placeholder="Username">
    </div>

    <div class="field-group">
      <label>Password</label>
      <input type="hidden" name="original__password" value="Password">
      <input type="text" name="field__password" placeholder="Password">
    </div>

    <div class="field-group">
      <label>Phone Number</label>
      <input type="hidden" name="original__phone" value="Phone Number">
      <input type="text" name="field__phone" placeholder="Phone Number">
    </div>

    <div class="field-group">
      <label>Email</label>
      <input type="hidden" name="original__email" value="Email">
      <input type="text" name="field__email" placeholder="Email">
    </div>

    <div class="field-group">
      <label>Choose Employee's Positions</label>
      <input type="hidden" name="original__choose_positions" value="Choose Employee's Positions">
      <input type="text" name="field__choose_positions" placeholder="Choose Employee's Positions">
    </div>

    <div class="field-group">
      <label>Register</label>
      <input type="hidden" name="original__register_button" value="Register">
      <input type="text" name="field__register_button" placeholder="Register">
    </div>

    <div class="field-group">
      <label>Cancel</label>
      <input type="hidden" name="original__cancel_button" value="Cancel">
      <input type="text" name="field__cancel_button" placeholder="Cancel">
    </div>

    <button type="submit">Generate Translated File</button>
  </form>
</body>
</html>
{% endblock %}