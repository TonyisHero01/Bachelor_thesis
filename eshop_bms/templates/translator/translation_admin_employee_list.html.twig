{% extends 'base.html.twig' %}

{% block title %}Translate – Auto Generated{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/translation_form.css') }}">
<form method="post" action="{{ path('translation_submit') }}">
    <input type="hidden" name="original_path" value="admin/employee_list.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>Employee List</label>
        <input type="hidden" name="original__auto_employee_list_2" value="Employee List">
        <input type="text" name="field__auto_employee_list_2" placeholder="Employee List">
    </div>
    <div class="field-group">
        <label>Add Employee</label>
        <input type="hidden" name="original__auto_add_employee_5" value="Add Employee">
        <input type="text" name="field__auto_add_employee_5" placeholder="Add Employee">
    </div>
    <div class="field-group">
        <label>Previous</label>
        <input type="hidden" name="original__auto_previous_14" value="Previous">
        <input type="text" name="field__auto_previous_14" placeholder="Previous">
    </div>
    <div class="field-group">
        <label>Next</label>
        <input type="hidden" name="original__auto_next_15" value="Next">
        <input type="text" name="field__auto_next_15" placeholder="Next">
    </div>
    <div class="field-group">
        <label>Page Count</label>
        <input type="hidden" name="original__auto_page_count_16" value="Page Count">
        <input type="text" name="field__auto_page_count_16" placeholder="Page Count">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}