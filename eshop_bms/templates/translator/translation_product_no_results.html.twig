{% extends 'base.html.twig' %}

{% block title %}Translate – Auto Generated{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/translation_form.css') }}">
<form method="post" action="{{ path('translation_submit') }}">
    <input type="hidden" name="original_path" value="product/no_results.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>No result Found</label>
        <input type="hidden" name="original__auto_no_result_found_0" value="No result Found">
        <input type="text" name="field__auto_no_result_found_0" placeholder="No result Found">
    </div>
    <div class="field-group">
        <label>Done</label>
        <input type="hidden" name="original__auto_done_1" value="Done">
        <input type="text" name="field__auto_done_1" placeholder="Done">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}