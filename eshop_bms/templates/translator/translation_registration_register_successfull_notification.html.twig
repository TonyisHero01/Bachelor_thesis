{% extends 'base.html.twig' %}

{% block title %}Translate – Auto Generated{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/translation_form.css') }}">
<form method="post" action="{{ path('translation_submit') }}">
    <input type="hidden" name="original_path" value="registration/register_successfull_notification.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>✅</label>
        <input type="hidden" name="original__auto___0" value="✅">
        <input type="text" name="field__auto___0" placeholder="✅">
    </div>
    <div class="field-group">
        <label>Registration Successful!</label>
        <input type="hidden" name="original__auto_registration_successful__1" value="Registration Successful!">
        <input type="text" name="field__auto_registration_successful__1" placeholder="Registration Successful!">
    </div>
    <div class="field-group">
        <label>You can now go to the homepage.</label>
        <input type="hidden" name="original__auto_you_can_now_go_to_the_homepage_2" value="You can now go to the homepage.">
        <input type="text" name="field__auto_you_can_now_go_to_the_homepage_2" placeholder="You can now go to the homepage.">
    </div>
    <div class="field-group">
        <label>Done</label>
        <input type="hidden" name="original__auto_done_3" value="Done">
        <input type="text" name="field__auto_done_3" placeholder="Done">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}