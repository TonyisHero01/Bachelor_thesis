{% extends 'base.html.twig' %}

{% block title %}Translate – Auto Generated{% endblock %}

{% block body %}
<form method="post" action="{{ path('translation_submit') }}">
    <input type="hidden" name="original_path" value="registration/register_successfull_notification.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>Register Successfull</label>
        <input type="hidden" name="original__auto_register_successfull_0" value="Register Successfull">
        <input type="text" name="field__auto_register_successfull_0" placeholder="Register Successfull">
    </div>
    <div class="field-group">
        <label>Register Successfull!!!</label>
        <input type="hidden" name="original__auto_register_successfull__1" value="Register Successfull!!!">
        <input type="text" name="field__auto_register_successfull__1" placeholder="Register Successfull!!!">
    </div>
    <div class="field-group">
        <label>Done</label>
        <input type="hidden" name="original__auto_done_2" value="Done">
        <input type="text" name="field__auto_done_2" placeholder="Done">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}