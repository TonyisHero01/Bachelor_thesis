{% extends 'base.html.twig' %}

{% block title %}Translate – Auto Generated{% endblock %}

{% block body %}
<form method="post" action="{{ path('translation_submit') }}">
    <input type="hidden" name="original_path" value="warehouse/index.html.twig">
    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>Order Tracking</label>
        <input type="hidden" name="original__auto_order_tracking_0" value="Order Tracking">
        <input type="text" name="field__auto_order_tracking_0" placeholder="Order Tracking">
    </div>
    <div class="field-group">
        <label>Return Requests</label>
        <input type="hidden" name="original__auto_return_requests_1" value="Return Requests">
        <input type="text" name="field__auto_return_requests_1" placeholder="Return Requests">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}