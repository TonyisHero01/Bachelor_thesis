    </div>
    <div class="field-group">
        <label>Password</label>
        <input type="hidden" name="original__auto_password_5" value="Password">
        <input type="text" name="field__auto_password_5" placeholder="Password">
    </div>
    <div class="field-group">
        <label>Sign in</label>
        <input type="hidden" name="original__auto_sign_in_6" value="Sign in">
        <input type="text" name="field__auto_sign_in_6" placeholder="Sign in">
