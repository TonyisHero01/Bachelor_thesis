    <input type="hidden" name="target_language" value="{{ lang }}">

    <div class="field-group">
        <label>⚫️</label>
        <input type="hidden" name="original__auto___3" value="⚫️">
        <input type="text" name="field__auto___3" placeholder="⚫️">
    </div>
    <div class="field-group">
        <label>sf</label>
        <input type="hidden" name="original__auto_sf_4" value="sf">
        <input type="text" name="field__auto_sf_4" placeholder="sf">
    </div>

    <button type="submit">Generate Translated File</button>
</form>
{% endblock %}