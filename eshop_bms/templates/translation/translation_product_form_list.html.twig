{% extends 'base.html.twig' %}

{% block title %}Translate Product – {{ lang|upper }}{% endblock %}

{% block body %}
<h2>🛠 Product Translation – {{ lang|upper }}</h2>

<p style="padding: 10px; background: #fff3cd; border: 1px solid #ffeeba; color: #856404;">
    Please click on a product below to start translating its content into <strong>{{ lang|upper }}</strong>.
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name (Original)</th>
            <th>Translated Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.name }}</td>
                <td>{{ translatedMap[product.id].name ?? '—' }}</td>
                <td>
                    <a href="{{ path('translation_product_detail_form', {'lang': lang, 'id': product.id}) }}" class="btn btn-primary">
                        Translate
                    </a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('translator_center', {'lang': lang}) }}" class="btn btn-secondary">← Back</a>
{% endblock %}