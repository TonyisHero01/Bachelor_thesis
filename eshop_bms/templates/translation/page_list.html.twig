{% extends 'base.html.twig' %}

{% block title %}Translation Pages{% endblock %}

{% block body %}
<h1>Choose a Page to Translate</h1>
<ul>
    <h3>BMS Pages</h3>
    {% for key, filename in bmsPages %}
        <li>
            <a href="{{ localized_path('translator_form', { path: filename, lang: lang }) }}">{{ key|replace({'_': ' '})|title }}</a>
        </li>
    {% endfor %}

    <h3>Frontweb Pages</h3>
    {% for key, filename in frontwebPages %}
        <li>
            <a href="{{ localized_path('frontweb_translator_form', { path: filename, lang: lang }) }}">{{ key|replace({'_': ' '})|title }}</a>
        </li>
    {% endfor %}
</ul>

<a href="{{ path('generate_all_translation_forms') }}" class="auto-btn">⚡ Generate All</a>

<style>
.auto-btn {
    margin-left: 10px;
    font-size: 0.9em;
    text-decoration: none;
    background: #f5f5f5;
    border: 1px solid #ccc;
    padding: 2px 6px;
    border-radius: 4px;
    color: #444;
}
.auto-btn:hover {
    background: #e2e2e2;
}
</style>
{% endblock %}