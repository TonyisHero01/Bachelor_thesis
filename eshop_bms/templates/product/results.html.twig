{% block search %}
    {# 不显示搜索表单 #}
{% endblock %}
{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Products List</title>
    <link rel="stylesheet" href="{{ asset('../assets/styles/product_list.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    {# 当前语言 hidden input，供 JS 读取 _locale #}
    <input type="hidden" id="current-locale" value="{{ app.request.get('_locale') }}">

    <div id='MAX_ARTICLES_COUNT_PER_PAGE' max_articles_count_per_page_value={{ MAX_ARTICLES_COUNT_PER_PAGE }}></div>
    <div id='NAME_MAX_LENGTH' name_max_length_value={{ NAME_MAX_LENGTH }}></div>
    <div id='CONTENT_MAX_LENGTH' content_max_length_value={{ CONTENT_MAX_LENGTH }}></div>

    <h1><a href="{{ localized_path('show_All_products') }}">Product List</a></h1>

    <table>
        <thead>
            <tr id="product_list_header">
                <th>Name</th>
                <th>Category</th>
                <th>Quantity</th>
                <th>Add Time</th>
                <th>Price</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            {% set ids = '' %}
            {% for product in products %}
                {% set ids = ids ~ product.id ~ ',' %}
                <tr id="{{ product.id }}" data-edit-route="{{ localized_path('product_edit', {'id': product.id}) }}"
                    {% if product.hidden %}style="background-color: #f0f0f0;"{% endif %}>
                    <td>{{ product.name }}</td> 
                    <td>{{ product.category }}</td>
                    <td>{{ product.numberInStock }}</td> 
                    <td>{{ product.createdAt|date('Y-m-d H:i') }}</td> 
                    <td>{{ product.price }}</td> 
                    <td><span class="edit-button" onclick="edit({{ product.id }})"><i class="fa-regular fa-pen-to-square" style="color: green;"></i></span></td>
                    <td><span class="delete-button" onclick="delete_({{ product.id }})"><i class="fas fa-trash" style="color: red;"></i></span></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <div id="ids" data-ids="{{ ids|trim(',') }}" style="display: none;"></div>
    
    <div class="buttons">
        <button id="previousPageButton" type="button" onclick="previousPage()">Previous</button>
        <button id="nextPageButton" type="button" onclick="nextPage()">Next</button>
        <span id="pageCount">Page Count </span>
    </div>

    <script src="{{ asset('../assets/productList.js') }}"></script>
    <script src="{{ asset('../assets/showPage.js') }}"></script>
    <script src="{{ asset('../assets/delete.js') }}"></script>
</body>
</html>
{% endblock %}