{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Product Details{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/product-show.css') }}">

<div class="product-container">
    <!-- 图片展示 -->
    <div class="product-images">
        <div class="image-slider">
            {% if product.imageUrls is not empty %}
                {% for imageUrl in product.imageUrls %}
                    <img src="{{ asset('images/' ~ imageUrl) }}" alt="{{ product.name }}" class="product-image" width="200" height="200">
                {% endfor %}
            {% else %}
                <img src="{{ asset('images/no-image.png') }}" alt="No Image Available" class="product-image" width="200" height="200">
            {% endif %}
        </div>
    </div>

    <!-- 商品详情 -->
    <div class="product-details">
        <h1>{{ product.name }}</h1>
        
        <p class="sku"><strong>SKU:</strong> {{ product.sku }}</p>
        <p class="category"><strong>Category:</strong> {{ product.category ?: 'No category' }}</p>
        <p class="description"><strong>Description:</strong> {{ product.description ?: 'No description available' }}</p>
        
        <p class="size"><strong>Size:</strong> {{ product.size ?: 'N/A' }}</p>
        <p class="dimensions">
            <strong>Dimensions:</strong> 
            {{ product.width ?: 'N/A' }} x {{ product.height ?: 'N/A' }} x {{ product.length ?: 'N/A' }} cm
        </p>
        <p class="weight"><strong>Weight:</strong> {{ product.weight ?: 'N/A' }} kg</p>
        <p class="material"><strong>Material:</strong> {{ product.material ?: 'N/A' }}</p>
        <p class="color"><strong>Color:</strong> {{ product.color ?: 'N/A' }}</p>

        <p class="stock">
            <strong>Stock:</strong> 
            {% if product.numberInStock > 0 %}
                <span class="in-stock">{{ product.numberInStock }} Available</span>
            {% else %}
                <span class="out-of-stock">Out of Stock</span>
            {% endif %}
        </p>

        <p class="price">
            <strong>Price:</strong> 
            <span class="original-price">{{ product.price|number_format(2) }}</span> 
            {{ product.currency.getName() }}
        </p>

        {% if product.discount < 100 %}
            <p class="discount">
                <strong>Discount:</strong> {{ product.discount }}%
            </p>
            <p class="final-price">
                <strong>Final Price:</strong> 
                {{ (product.price * product.discount / 100)|number_format(2) }} {{ product.currency.getName() }}
            </p>
        {% endif %}

        <p class="tax-rate"><strong>Tax Rate:</strong> {{ product.taxRate }}%</p>
    </div>
</div>

{% endblock %}