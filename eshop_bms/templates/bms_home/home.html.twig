{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="{{ asset('../assets/styles/home.css') }}">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
  <div class="content">
    Hi {{ app.user.name ?: '' }} {{ app.user.surname ?: '' }}
    <br>
    <a href="/{{ app.user ? 'logout' : 'login' }}">
        {{ app.user ? (translations.logout ?? 'Logout') : (translations.login ?? 'Login') }}
    </a>

    {% if 'ROLE_SUPER_ADMIN' in roles %}
    <form action="#" enctype="multipart/form-data">
      <label for="eshop_name">{{ translations.eshop_name ?? 'Eshop Name' }}</label>
      <input type="text" id="eshop_name" name="eshop_name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.eshopName }}"><br>

      <label for="company_name">{{ translations.company_name ?? 'Company Name' }}</label>
      <input type="text" id="company_name" name="company_name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.companyName }}"><br>

      <label for="cin">{{ translations.cin ?? 'CIN Number' }}</label>
      <input type="text" id="cin" name="cin" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.cin }}"><br>

      <label for="address">{{ translations.address ?? 'Address' }}</label>
      <input type="text" id="address" name="address" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.address }}"><br>

      <label for="tel">{{ translations.telephone ?? 'Telephone' }}</label>
      <input type="text" id="tel" name="tel" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.telephone }}"><br>

      <label for="email">{{ translations.email ?? 'Email' }}</label>
      <input type="text" id="email" name="email" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ shopInfo.email }}"><br>

      <label for="about">{{ translations.about_us ?? 'About Us' }}</label><br>
      <textarea id="about" name="about" rows="15">{{ shopInfo.aboutUs }}</textarea><br>

      <label for="how_to_order">{{ translations.how_to_order ?? 'How to order' }}</label><br>
      <textarea id="how_to_order" name="how_to_order" rows="15">{{ shopInfo.howToOrder }}</textarea><br>

      <label for="conditions">{{ translations.business_conditions ?? 'Business Conditions' }}</label><br>
      <textarea id="conditions" name="conditions" rows="15">{{ shopInfo.businessConditions }}</textarea><br>

      <label for="privacy">{{ translations.privacy_policy ?? 'Privacy Policy' }}</label><br>
      <textarea id="privacy" name="privacy" rows="15">{{ shopInfo.privacyPolicy }}</textarea><br>

      <label for="shipping">{{ translations.shipping_info ?? 'Shipping Info' }}</label><br>
      <textarea id="shipping" name="shipping" rows="15">{{ shopInfo.shippingInfo }}</textarea><br>

      <label for="payment">{{ translations.payment ?? 'Payment' }}</label><br>
      <textarea id="payment" name="payment" rows="15">{{ shopInfo.payment }}</textarea><br>

      <label for="refund">{{ translations.refund ?? 'Refund' }}</label><br>
      <textarea id="refund" name="refund" rows="15">{{ shopInfo.refund }}</textarea><br>

      <label for="hide_prices">{{ translations.hide_prices ?? 'Hide Prices' }}</label>
      <input type="checkbox" id="hide_prices" name="hide_prices" {% if shopInfo.hidePrices %}checked{% endif %}>

      <label for="logo_url">LOGO</label><br>
      <img id="logo_preview" src="{{ shopInfo.logo ? asset('images/' ~ shopInfo.logo) : '' }}" alt="Logo" width="304" height="228"><br>
      <input id="logo_url" type="file" accept="image/*" onchange="handleLogoUpload(event)">
      <input type="hidden" id="logo_path" value="{{ shopInfo.logo }}">

      <label for="carousel_urls">{{ translations.carousel_pictures ?? 'Carousel Pictures' }}</label><br>

      <div id="image_container">
        {% if shopInfo.carouselPictures is not empty %}
          {% for imageUrl in shopInfo.carouselPictures %}
            <div class="image_upload_section" data-image-url="{{ imageUrl }}">
              <img id="image" src="{{ asset('images/' ~ imageUrl) }}" alt="{{ shopInfo.eshopName }}" width="304" height="228"><br>
              <button type="button" class="delete-button" onclick="deleteImage('{{ imageUrl }}')"><i class="fas fa-trash" style="color: red;"></i></button>
            </div>
          {% endfor %}
        {% else %}
          <div class="image_upload_section">
            <p>No images uploaded yet</p>
          </div>
        {% endif %}
        <input class="image_upload_input" type="file" multiple>
        <input type="hidden" class="image_path" value="">
      </div>

      <h2>{{ translations.manage_currencies ?? 'Manage Currencies' }}</h2>
      <div id="currency-container">
        {% for currency in currencies %}
          <div class="currency-pair" data-currency-id="{{ currency.id }}">
            <input type="text" name="currencyCode[]" placeholder="{{ translations.currency_code ?? 'Currency Code (e.g., USD)' }}" value="{{ currency.name }}" required>
            <input type="number" name="currencyValue[]" placeholder="{{ translations.value ?? 'Value' }}" value="{{ currency.value }}" step="0.01" required>
            <input type="radio" name="isDefaultCurrency" value="{{ currency.id }}" {% if currency.isDefault %}checked{% endif %}> {{ translations.default ?? 'Default' }}
            <button type="button" class="delete-currency" onclick="deleteCurrency(this)">Delete</button>
          </div>
        {% endfor %}
      </div>
      <button type="button" id="addCurrencyButton" onclick="addCurrency()">{{ translations.add_currency ?? 'Add Currency' }}</button>

      <div class="buttons">
        <button type="button" id="saveButton" onclick="save_()">{{ translations.save ?? 'Save' }}</button>
        <button type="button" id="backButton" onclick="discard()">{{ translations.discard_changes ?? 'Discard Changes' }}</button>
        <script src="{{ asset('../assets/eshopEdit.js') }}"></script>
    </form>
    {% endif %}

    {% if 'ROLE_WAREHOUSEMAN' in roles %}
    <hr>
    <h2 style="margin-top: 50px;">📊 Dashboard</h2>

    <div style="max-width: 1000px;">
      <h3>📈 Sales in the Last 30 Days</h3>
      <canvas id="salesChart"></canvas>

      <h3>🔥 Top 5 Best-Selling Products</h3>
      <canvas id="topProductsChart"></canvas>

      <h3>💰 Top 5 Customers by Spending</h3>
      <canvas id="topCustomersChart"></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      const salesData = {{ sales|json_encode|raw }};
      const topProducts = {{ topProducts|json_encode|raw }};
      const topCustomers = {{ topCustomers|json_encode|raw }};

      new Chart(document.getElementById('salesChart'), {
        type: 'line',
        data: {
          labels: salesData.map(d => d.date),
          datasets: [{
            label: 'Sales (CZK)',
            data: salesData.map(d => parseFloat(d.total)),
            fill: true,
            tension: 0.1
          }]
        }
      });

      new Chart(document.getElementById('topProductsChart'), {
        type: 'bar',
        data: {
          labels: topProducts.map(d => d.product_name),
          datasets: [{
            label: 'Quantity Sold',
            data: topProducts.map(d => parseFloat(d.total_quantity))
          }]
        }
      });

      new Chart(document.getElementById('topCustomersChart'), {
        type: 'bar',
        data: {
          labels: topCustomers.map(d => d.email),
          datasets: [{
            label: 'Total Spent (CZK)',
            data: topCustomers.map(d => parseFloat(d.total_spent))
          }]
        }
      });

      
    </script>
    {% endif %}
  </div>

  <div class="sidebar">
    <h3>Your Roles</h3>
    <ul>
      {% if 'ROLE_SUPER_ADMIN' in roles %}
        <li><a href='{{ localized_path('show_All_admins') }}'>{{ translations.role_super_admin ?? 'SUPER ADMIN' }}</a></li>
        <li style="margin-left: 20px;">
          <button onclick="getAdminCode()" style="color:green; font-weight:bold; background:none; border:none; cursor:pointer;">
            🔐 Get programming verification code
          </button>
        </li>
      {% endif %}
      {% if 'ROLE_ADMIN' in roles %}
        <li><a href='{{ localized_path('show_All_employees') }}'>{{ translations.role_admin ?? 'ADMINISTRATOR' }}</a></li>
      {% endif %}
      {% if 'ROLE_WAREHOUSEMAN' in roles %}
        <li><a href='{{ localized_path('app_warehouse') }}'>{{ translations.role_warehouseman ?? 'WAREHOUSEMAN' }}</a></li>
      {% endif %}
      {% if 'ROLE_WAREHOUSE_MANAGER' in roles %}
        <li><a href='{{ localized_path('show_All_products') }}'>{{ translations.role_warehouse_manager ?? 'WAREHOUSE MANAGER' }}</a></li>
      {% endif %}
      {% if 'ROLE_TRANSLATOR' in roles %}
        <li><a href='{{ localized_path('translator_languages') }}'>{{ translations.role_translator ?? 'TRANSLATOR' }}</a></li>
      {% endif %}
      {% if 'ROLE_EVENT_MANAGER' in roles %}
        <li><a href='{{ localized_path('event_manager_discounts') }}'>{{ translations.role_event_manager ?? 'EVENT MANAGER' }}</a></li>
      {% endif %}
      {% if 'ROLE_ACCOUNTING' in roles %}
        <li><a href='{{ localized_path('accounting') }}'>{{ translations.role_accounting ?? 'ACCOUNTING' }}</a></li>
      {% endif %}
        <li>General Functions</li>
        <li style="margin-left: 40px;"><a href='{{ localized_path('code_playground') }}'>Code Editor</a></li>
    </ul>
  </div>
  <div id="codeModal" style="display:none; position:fixed; top:20%; left:50%; transform:translateX(-50%);
      background:white; border:1px solid #ccc; padding:20px; box-shadow: 0 0 10px rgba(0,0,0,0.3); z-index:1000;">
      <h3>Current verification code: </h3>
      <p id="adminCodeDisplay" style="font-size:1.5em; color:red;">加载中...</p>
      <button onclick="copyCode()">Copy</button>
      <button onclick="closeModal()">Close</button>
  </div>
  <div id="modalOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
      background:rgba(0,0,0,0.5); z-index:999;" onclick="closeModal()"></div>
  <div class="admin-code" data-api="{{ path('admin_get_code_api') }}"></div>

  <script src="{{ asset('../assets/adminCode.js') }}"></script>
</body>
</html>
{% endblock %}
