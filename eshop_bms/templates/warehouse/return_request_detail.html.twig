{% extends 'base.html.twig' %}

{% block title %}Return Request Details{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('assets/styles/return_request_detail.css') }}">

<div class="example-wrapper">
    <h2>Return Request #{{ request.getId() }}</h2>

    <table class="styled-table">
        <tr>
            <th>Order ID</th>
            <td>{{ request.getOrder().getId() }}</td>
        </tr>
        <tr>
            <th>Customer Name</th>
            <td>{{ request.getUserName() }}</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>{{ request.getUserEmail() }}</td>
        </tr>
        <tr>
            <th>Phone</th>
            <td>{{ request.getUserPhone() }}</td>
        </tr>
        <tr>
            <th>Return Reason</th>
            <td>{{ request.getReturnReason() ?: 'N/A' }}</td>
        </tr>
        <tr>
            <th>Products (SKUs)</th>
            <td>{{ request.getProductSkus() }}</td>
        </tr>
        <tr>
            <th>Request Date</th>
            <td>{{ request.getRequestDate().format('Y-m-d H:i') }}</td>
        </tr>
        <tr>
            <th>Message</th>
            <td>{{ request.getUserMessage() ?: 'N/A' }}</td>
        </tr>
    </table>

    <div class="action-buttons">
        <button class="accept-btn" onclick="processReturnRequest({{ request.getId() }}, 'accepted')">Accept</button>
        <button class="reject-btn" onclick="processReturnRequest({{ request.getId() }}, 'rejected')">Reject</button>
    </div>

    <a href="{{ localized_path('app_return_requests') }}" class="back-btn">Back to Return Requests</a>
</div>

<script src="{{ asset('assets/returnRequestDetail.js') }}"></script>

{% endblock %}