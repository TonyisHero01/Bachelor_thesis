{% extends 'base.html.twig' %}

{% block title %}Employee Registration{% endblock %}

{% block body %}
    <h1>Registrace zaměstnanců</h1>

    {{ form_start(registrationForm) }}
    
    {{ form_row(registrationForm.surname, {'label': 'Surname'}) }}
    {{ form_row(registrationForm.name, {'label': 'Name'}) }}
    {{ form_row(registrationForm.username, {'label': 'Username'}) }}
    {{ form_row(registrationForm.plainPassword, {'label': 'Password'}) }}
    {{ form_row(registrationForm.phoneNumber, {'label': 'Phone Number'}) }}
    {{ form_row(registrationForm.email, {'label': 'Email'}) }}

    <fieldset>
        <legend>Vyberte Zaměstnanecké pozice</legend>
        {{ form_row(registrationForm.roles) }}
    </fieldset>

    <div class="buttons">
        <button type="submit" class="btn">Registrovat</button>
        <button type="button" class="btn" onclick="history.back()">Zrušit</button>
    </div>

    {{ form_end(registrationForm) }}
{% endblock %}