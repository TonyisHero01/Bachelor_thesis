{% extends 'base.html.twig' %}

{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Product List</title>
    <link rel="stylesheet" href="{{ asset('../assets/styles/app.css') }}">
</head>
<body>
    <h1>Úprava produktu</h1>
    <div id=productId product-id-data={{ product.id }}></div>
    <div id="routeData" data-product_list-route="{{ localized_path('show_All_products') }}"></div>
    <div id="body">
    
    <form action="#"  enctype="multipart/form-data">
        <label for="versionSelect">Vyberte verzi:</label>
        <select id="versionSelect" name="versionSelect" onchange="switchVersion(this.value)">
            {% for productVersion in productsWithSameSku %}
                <option value="{{ localized_path('edit_product', {'id': productVersion.id}) }}"
                    {% if productVersion.id == product.id %}selected{% endif %}>
                    Version {{ productVersion.version }} - {{ productVersion.addTime|date('Y-m-d H:i') }}
                </option>
            {% endfor %}
        </select>
        <label for="name">Název</label>
        <input type="text" id="name" name="name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ product.name }}"><br>
        <p id="last modified">Přidán čas:</p>
        <p id="add_time">{{ product.addTime }}</p>
        <div id="sku">SKU: {{ product.sku }}</div>
        <label for="categoryOptions">Vyberte kategorii:</label><br>
        <select id="categoryOptions" name="categoryOptions">
            {% for category in categories %}
                <option value="{{ category.id }}" {% if category.name == product.category %}selected{% endif %}>{{category.name}}</option>
            {% endfor %}
        </select><br>
        <label for="description">Popis</label><br>
        <textarea id="description" name="description" rows="15" value="{{ product.description }}">{{ product.description }}</textarea><br>
        <label for="number_in_stock">Číslo skladem</label><br>
        <input type="text" id="number_in_stock" name="numberInStock" value="{{ product.numberInStock }}"><br>
        <label for="image_urls">Obrázky</label><br>
        <div id="image_container">
            {% if product.imageUrls is not empty %}
                {% for imageUrl in product.imageUrls %}
                    <div class="image_upload_section" data-image-url="{{imageUrl}}">
                        <img id="image" src="{{ asset('images/' ~ imageUrl) }}" alt="{{ product.name }}" width="304" height="228"><br>
                        <button type="button" class="delete-button" onclick="deleteImage('{{ imageUrl }}')">Smazat obrázek</button>
                    </div>
                {% endfor %}
            {% else %}
                <div class="image_upload_section">
                    <p>Dosud nebyly nahrány žádné obrázky</p>
                </div>
            {% endif %}
            <input class="image_upload_input" type="file" multiple>
            <input type="hidden" class="image_path" value="">
        </div>
        <label for="sizeOptions">Vyberte velikost:</label><br>
        <select id="sizeOptions" name="sizeOptions">
            <option value="">Žádný</option> <!-- 默认无尺寸 -->
            {% for size in sizes %}
                <option value="{{ size.name }}" {% if size.name == product.size %}selected{% endif %}>
                    {{ size.name }}
                </option>
            {% endfor %}
        </select><br>
        <label for="width">Šířka</label><br>
        <input type="number" id="width" name="width" value="{{ product.width }}" step="0.01" min="0"><br>
        <label for="height">Výška</label>
        <input type="number" id="height" name="height" value="{{ product.height }}" step="0.01" min="0">
        <label for="length">Délka</label>
        <input type="number" id="length" name="length" value="{{ product.length }}" step="0.01" min="0"><br>
        <label for="weight">Hmotnost</label>
        <input type="number" id="weight" name="weight" value="{{ product.weight }}" step="0.01" min="0"><br>
        <label for="material">Materiál</label>
        <input type="text" id="material" name="material" value="{{ product.material }}"><br>
        <label for="colorOptions">Vyberte barvu:</label><br>
        <select id="colorOptions" name="colorOptions">
            {% for color in colors %}
                <option value="{{ color.name }}" {% if color.name == product.color %}selected{% endif %}>{{ color.name }}</option>
            {% endfor %}
        </select><br>
        <div id="attributes-container">
            <label>Extra atributy:</label><br>
            {% if product.attributes is not empty %}
                {% for key, value in product.attributes %}
                    <div class="attribute-pair">
                        <input type="text" name="attributeKey[]" placeholder="Key" value="{{ key }}" required>
                        <input type="text" name="attributeValue[]" placeholder="Value" value="{{ value }}" required>
                        <button type="button" class="delete-attribute" onclick="deleteAttribute(this)">Vymazat</button>
                    </div>
                {% endfor %}
            {% else %}
                <div class="attribute-pair">
                    <input type="text" name="attributeKey[]" placeholder="Key" required>
                    <input type="text" name="attributeValue[]" placeholder="Value" required>
                </div>
            {% endif %}
        </div>
        <button type="button" id="addAttributeButton" onclick="addAttribute()">Přidat atribut</button><br>
        <label for="price">Cena</label>
        <input type="number" id="price" name="price" value="{{ product.price }}" step="0.01" min="0"><br>
        <div id="currency">Currency: {{product.currency}}</div>
        <label for="discount">Sleva</label>
        <input type="number" id="discount" name="discount" value="{{ product.discount }}" step="0.01" min="0"><br>
        <label for="tax_rate">Daňová sazba (%)</label>
        <input type="number" id="tax_rate" name="tax_rate" value="{{ product.taxRate }}" step="0.1" min="0"><br>
        <label for="hideBox">
            <input type="checkbox" id="hideBox" name="hideBox" {% if product.hidden %}checked{% endif %}>Skrýt produkt</label><br>
        <div class="buttons">
        <button type="button" id="saveButton" onclick="save_()">Uložit</button>
        <button type="button" id="backButton" onclick="backToProducts()">Zpět k produktům</button>
        <script src="{{ asset('../assets/edit.js') }}"></script>
    </form>
    </div>
</body>
</html>
{% endblock %}