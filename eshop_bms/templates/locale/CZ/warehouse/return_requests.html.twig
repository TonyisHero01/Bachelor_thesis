{% extends 'base.html.twig' %}

{% block title %}Return Requests{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/app.css') }}">

<div class="example-wrapper">
    <h2>Žádosti o vrácení</h2>

    {% if returnRequests is empty %}
        <p>Nebyly nalezeny žádné žádosti o vrácení.</p>
    {% else %}
        <table class="styled-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ID objednávky</th>
                    <th>Jméno zákazníka</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Důvod návratu</th>
                    <th>Produkty (SKU)</th>
                    <th>Datum požadavku</th>
                    <th>Status</th>
                    <th>Akce</th> 
                </tr>
            </thead>
            <tbody>
                {% for request in returnRequests %}
                    <tr class="status-{{ request.getStatus() }}">
                        <td>{{ request.getId() }}</td>
                        <td>{{ request.getOrder().getId() }}</td>
                        <td>{{ request.getUserName() }}</td>
                        <td>{{ request.getUserEmail() }}</td>
                        <td>{{ request.getUserPhone() }}</td>
                        <td>{{ request.getReturnReason() ?: 'N/A' }}</td>
                        <td>{{ request.getProductSkus() }}</td>
                        <td>{{ request.getRequestDate().format('Y-m-d H:i') }}</td>
                        <td>{{ request.getStatus()|capitalize }}</td>
                        <td>
                            <a href="{{ localized_path('return_request_detail', { 'id': request.getId() }) }}" class="view-btn">Zobrazit podrobnosti</a>
                        </td> 
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

<style>
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        margin: 25px 0;
        font-size: 18px;
        text-align: left;
    }

    .styled-table thead tr {
        background-color: #009879;
        color: #ffffff;
        text-align: left;
    }

    .styled-table th, .styled-table td {
        padding: 12px 15px;
        border: 1px solid #ddd;
    }

    .styled-table tbody tr:nth-child(even) {
        background-color: #f3f3f3;
    }

    /* ✅ 状态颜色 */
    .status-pending {
        background-color: white; /* 白色 */
    }

    .status-accepted {
        background-color: #c3e6cb; /* 绿色 */
    }

    .status-rejected {
        background-color: #f5c6cb; /* 红色 */
    }

    /* ✅ 详情按钮 */
    .view-btn {
        display: inline-block;
        padding: 5px 10px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        font-size: 14px;
    }

    .view-btn:hover {
        background-color: #0056b3;
    }
</style>

{% endblock %}