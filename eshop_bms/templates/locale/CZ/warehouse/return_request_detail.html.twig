{% extends 'base.html.twig' %}

{% block title %}Return Request Details{% endblock %}

{% block body %}
<link rel="stylesheet" href="{{ asset('../assets/styles/app.css') }}">

<div class="example-wrapper">
    <h2>Return Request #{{ request.getId() }}</h2>

    <table class="styled-table">
        <tr>
            <th>ID objednávky</th>
            <td>{{ request.getOrder().getId() }}</td>
        </tr>
        <tr>
            <th>Jméno zákazníka</th>
            <td>{{ request.getUserName() }}</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>{{ request.getUserEmail() }}</td>
        </tr>
        <tr>
            <th>Telefon</th>
            <td>{{ request.getUserPhone() }}</td>
        </tr>
        <tr>
            <th>Důvod návratu</th>
            <td>{{ request.getReturnReason() ?: 'N/A' }}</td>
        </tr>
        <tr>
            <th>Produkty (SKU)</th>
            <td>{{ request.getProductSkus() }}</td>
        </tr>
        <tr>
            <th>Datum požadavku</th>
            <td>{{ request.getRequestDate().format('Y-m-d H:i') }}</td>
        </tr>
        <tr>
            <th>Zpráva</th>
            <td>{{ request.getUserMessage() ?: 'N/A' }}</td>
        </tr>
    </table>

    <div class="action-buttons">
        <button class="accept-btn" onclick="processReturnRequest({{ request.getId() }}, 'accepted')">Přijmout</button>
        <button class="reject-btn" onclick="processReturnRequest({{ request.getId() }}, 'rejected')">Odmítnout</button>
    </div>

    <a href="{{ localized_path('app_return_requests') }}" class="back-btn">Zpět na Žádosti o vrácení</a>
</div>

<script>
    function processReturnRequest(requestId, status) {
        if (!confirm(`Are you sure you want to ${status} this return request?`)) {
            return;
        }

        fetch(`/warehouse/return-request/${requestId}/process`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(`Return request has been ${status}.`);
                window.location.reload();
            } else {
                alert("Error: " + data.message);
            }
        })
        .catch(error => console.error("Error:", error));
    }
</script>

<style>
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        margin: 25px 0;
        font-size: 18px;
        text-align: left;
    }

    .styled-table th, .styled-table td {
        padding: 12px 15px;
        border: 1px solid #ddd;
    }

    .styled-table thead tr {
        background-color: #009879;
        color: #ffffff;
        text-align: left;
    }

    .action-buttons {
        margin-top: 20px;
    }

    .accept-btn, .reject-btn {
        padding: 10px 15px;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 5px;
        font-size: 16px;
        margin-right: 10px;
    }

    .accept-btn {
        background-color: #28a745;
    }

    .accept-btn:hover {
        background-color: #218838;
    }

    .reject-btn {
        background-color: #dc3545;
    }

    .reject-btn:hover {
        background-color: #c82333;
    }

    .back-btn {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 15px;
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        border-radius: 5px;
    }

    .back-btn:hover {
        background-color: #5a6268;
    }
</style>

{% endblock %}