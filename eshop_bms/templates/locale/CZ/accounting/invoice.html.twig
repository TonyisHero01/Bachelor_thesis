
{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            margin: 0;
            padding: 30px;
            color: #333;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo {
            width: 120px;
            height: auto;
            margin-bottom: 10px;
        }

        h1 {
            margin: 5px 0;
            font-size: 20px;
        }

        .meta, .customer-info {
            margin-bottom: 25px;
        }

        .meta p, .customer-info p {
            margin: 3px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        thead {
            background-color: #f0f0f0;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px 10px;
            text-align: left;
        }

        .totals {
            text-align: right;
            margin-top: 20px;
        }

        .totals strong {
            font-size: 14px;
        }

        footer {
            margin-top: 40px;
            font-size: 11px;
            text-align: center;
            color: #777;
        }
    </style>
</head>
<body>
    <header>
        {# 如果你有 logo，可以这样插入 #}
        {# <img src="{{ absolute_url(asset('images/logo.png')) }}" alt="Logo" class="logo"> #}
        <h1>INVOICE #{{ order.id }}</h1>
    </header>

    <div class="meta">
        <p><strong>Datum</strong> {{ order.orderCreatedAt|date('Y-m-d') }}</p>
        <p><strong>Status</strong> {{ order.paymentStatus }}</p>
    </div>

    <div class="customer-info">
        <p><strong>Zákazník:</strong> {{ order.customer.email }}</p>
        <p><strong>Kontakt:</strong></p>
        {% for line in order.address|split(';') %}
            <p>{{ line|trim }}</p>
        {% endfor %}
        <p><strong>Dodání:</strong> {{ order.deliveryMethod|capitalize }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Položka</th>
                <th>Množství</th>
                <th>Jednotková cena</th>
                <th>Mezisoučet</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ item.productName }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ item.unitPrice|number_format(2, '.', ',') }}</td>
                    <td>{{ item.subtotal|number_format(2, '.', ',') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        {% set subtotal = 0 %}
        {% for item in order.orderItems %}
            {% set subtotal = subtotal + item.subtotal %}
        {% endfor %}

        {% set discount = order.discount %}
        {% set totalAfterDiscount = order.totalPrice - discount %}
        {% set taxAmount = totalAfterDiscount - subtotal %}

        <p>Subtotal (without tax): {{ subtotal|number_format(2, '.', ',') }} {{ order.customer.preferredCurrency ?? 'CZK' }}</p>
        {% if discount > 0 %}
            <p>Discount: -{{ discount|number_format(2, '.', ',') }} {{ order.customer.preferredCurrency ?? 'CZK' }}</p>
        {% endif %}
        <p>Tax: {{ taxAmount|number_format(2, '.', ',') }} {{ order.customer.preferredCurrency ?? 'CZK' }}</p>
        <p><strong>Total (incl. tax): {{ totalAfterDiscount|number_format(2, '.', ',') }} {{ order.customer.preferredCurrency ?? 'CZK' }}</strong></p>
    </div>

    <footer>Děkujeme za vaši objednávku!<br>
        For support, contact {{ shopInfo.email ?? 'support@example.com' }}
    </footer>
</body>
</html>
{% endblock %}