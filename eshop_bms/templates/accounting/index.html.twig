{% extends 'base.html.twig' %}

{% block body %}
    <h1>Completed Orders</h1>
    <table>
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Total</th>
                <th>Date</th>
                <th>Email</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
                <tr>
                    <td>{{ order.id }}</td>
                    <td>{{ order.totalPrice }} CZK</td>
                    <td>{{ order.orderCreatedAt|date('Y-m-d') }}</td>
                    <td>{{ order.customer.email }}</td>
                    <td>
                        <a href="{{ localized_path('accounting_order_detail', {id: order.id}) }}">View</a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6">No completed orders found.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}