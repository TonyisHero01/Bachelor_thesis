{% block body %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            margin: 0;
            padding: 30px;
            color: #333;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo {
            width: 120px;
            height: auto;
            margin-bottom: 10px;
        }

        h1 {
            margin: 5px 0;
            font-size: 20px;
        }

        .meta, .customer-info {
            margin-bottom: 25px;
        }

        .meta p, .customer-info p {
            margin: 3px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        thead {
            background-color: #f0f0f0;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px 10px;
            text-align: left;
        }

        .totals {
            text-align: right;
            margin-top: 20px;
        }

        .totals strong {
            font-size: 14px;
        }

        footer {
            margin-top: 40px;
            font-size: 11px;
            text-align: center;
            color: #777;
        }
    </style>
</head>
<body>
    <header>
        {# <img src="{{ absolute_url(asset('images/logo.png')) }}" alt="Logo" class="logo"> #}
        <h1>INVOICE #{{ order.id }}</h1>
    </header>

    <div class="meta">
        <p><strong>Date:</strong> {{ order.orderCreatedAt|date('Y-m-d') }}</p>
        <p><strong>Status:</strong> {{ order.paymentStatus }}</p>
    </div>

    <div class="customer-info">
        <p><strong>Customer:</strong> {{ order.customer.email }}</p>
        <p><strong>Contact:</strong></p>
        {% for line in order.address|split(';') %}
            <p>{{ line|trim }}</p>
        {% endfor %}
        <p><strong>Delivery:</strong> {{ order.deliveryMethod|capitalize }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Item</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ item.productName }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ money(item.unitPrice) }}</td>
                    <td>{{ money(item.subtotal) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        {# 小计：所有行小计求和 #}
        {% set subtotal = 0 %}
        {% for item in order.orderItems %}
            {% set subtotal = subtotal + item.subtotal %}
        {% endfor %}

        {# 折扣、税额、合计 #}
        {% set discount = order.discount %}
        {% set totalAfterDiscount = order.totalPrice - discount %}
        {% set taxAmount = totalAfterDiscount - subtotal %}

        <p>Subtotal (without tax): {{ money(subtotal) }}</p>

        {% if discount > 0 %}
            <p>Discount: -{{ money(discount) }}</p>
        {% endif %}

        <p>Tax: {{ money(taxAmount) }}</p>
        <p><strong>Total (incl. tax): {{ money(totalAfterDiscount) }}</strong></p>
    </div>

    <footer>
        Thank you for your order!<br>
        For support, contact {{ shopInfo.email ?? 'support@example.com' }}
    </footer>
</body>
</html>
{% endblock %}