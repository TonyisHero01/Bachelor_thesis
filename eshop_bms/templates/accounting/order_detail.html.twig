{% extends 'base.html.twig' %}

{% block title %}Order Detail - #{{ order.id }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/styles/accounting_order_detail.css') }}">
{% endblock %}

{% block body %}
    <h1>{{ 'Order'|trans }} #{{ order.id }} {{ 'Detail'|trans }}</h1>

    <p><strong>Email:</strong> {{ order.customer.email }}</p>

    <p><strong>Contact:</strong><br>
        {% for line in order.address|split(';') %}
            {{ line|trim }}<br>
        {% endfor %}
    </p>

    <p><strong>Created At:</strong> {{ order.orderCreatedAt|date('Y-m-d H:i') }}</p>
    <p><strong>Total:</strong> {{ money(order.totalPrice) }}</p>

    <h3>Order Items:</h3>
    <ul>
        {% for item in order.orderItems %}
            {% set lineSubtotal = (item.unitPrice ?? 0) * (item.quantity ?? 0) %}
            <li>
                {{ item.productName }}
                × {{ item.quantity }}
                = {{ money(lineSubtotal) }}
                <span style="color:#6b7280;">({{ money(item.unitPrice) }}/unit)</span>
            </li>
        {% endfor %}
    </ul>

    <a href="{{ localized_path('accounting_invoice_pdf', {id: order.id}) }}" class="btn btn-primary" target="_blank" rel="noopener">
        {{ translations.download_pdf ?? 'Download PDF' }}
    </a>

    <form
        method="post"
        action="{{ localized_path('accounting_invoice_send', {id: order.id}) }}"
        style="display:inline;"
    >
        <input type="hidden" name="_token" value="{{ csrf_token('send_invoice_' ~ order.id) }}">
        <button type="submit" class="btn btn-success">
            {{ translations.send_invoice ?? 'Send Invoice by Email' }}
        </button>
    </form>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
{% endblock %}