{# templates/admin/employee_edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Employee Edit{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/styles/employee_edit.css') }}">
{% endblock %}

{% block body %}
<h1>Employee Edit</h1>

<div id="employeeId" data-employee-id="{{ employee.id }}"></div>
<div id="routeData" data-employee_list-route="{{ localized_path('show_All_employees') }}"></div>

<form action="#" enctype="multipart/form-data">
    <label for="surname">Surname</label>
    <input type="text" id="surname" name="surname" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ employee.surname }}"><br>

    <label for="name">Name</label>
    <input type="text" id="name" name="name" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ employee.name }}"><br>

    <label for="phoneNumber">Phone Number</label>
    <input type="number" id="phoneNumber" name="phoneNumber" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ employee.phoneNumber }}"><br>

    <label for="email">Email</label>
    <input type="text" id="email" name="email" required maxlength="{{ NAME_MAX_LENGTH }}" value="{{ employee.email }}"><br>

    <fieldset>
        <legend>Choose Employee's Positions</legend>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_WAREHOUSEMAN"
                {% if 'ROLE_WAREHOUSEMAN' in employee.roles %} checked {% endif %}>
            Warehouseman
        </label><br>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_WAREHOUSE_MANAGER"
                {% if 'ROLE_WAREHOUSE_MANAGER' in employee.roles %} checked {% endif %}>
            Warehouse Manager
        </label><br>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_TRANSLATOR"
                {% if 'ROLE_TRANSLATOR' in employee.roles %} checked {% endif %}>
            Translator
        </label><br>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_EVENT_MANAGER"
                {% if 'ROLE_EVENT_MANAGER' in employee.roles %} checked {% endif %}>
            Event Manager
        </label><br>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_ACCOUNTING"
                {% if 'ROLE_ACCOUNTING' in employee.roles %} checked {% endif %}>
            Accounting
        </label><br>

        <label>
            <input type="checkbox" name="roles[]" value="ROLE_ADMIN"
                {% if 'ROLE_ADMIN' in employee.roles %} checked {% endif %}>
            Administrator
        </label>
    </fieldset>

    <div class="buttons">
        <button type="button" id="saveButton" onclick="save_()">Save</button>
        <button type="button" id="backButton" onclick="backToEmployees()">Back to Employees</button>
    </div>
</form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/employeeEdit.js') }}"></script>
{% endblock %}