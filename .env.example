GHCR_NAMESPACE=ghcr.io/tonyishero01
IMAGE_TAG=latest

# =========================
# Symfony
# =========================
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=75d2222c239930c8fc40c98ae6b88cb6d9dfacf51c5c8c0749583fc681de9d9a
PHP_UPLOAD_MAX_FILESIZE=20M
PHP_POST_MAX_SIZE=25M
