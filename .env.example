PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# =========================
# Python API
# =========================
SEARCH_SERVICE_BASE_URL=http://search-service:8000
SEARCH_API_KEY=RsY1J2Gv3y_OfIuuLG_bTatlViwX6QHuXqdscXR9BbY
MAX_SEARCH_LIMIT=200
DEFAULT_SEARCH_LIMIT=50
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# =========================
# Mail
# =========================
MAILER_DSN=smtp://<user>:<password>@<host>:<port>?encryption=tls

# =========================
# App config
# =========================
